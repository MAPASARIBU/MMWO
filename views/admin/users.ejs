<div class="card">
    <div class="flex justify-between items-center mb-4">
        <h3>User Management</h3>
        <button onclick="openModal('createUserModal')" class="btn btn-primary">+ Add New User</button>
    </div>

    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>Username</th>
                    <th>Name</th>
                    <th>WhatsApp / Phone</th>
                    <th>Role</th>
                    <th>Mill</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach(u=> { %>
                    <tr>
                        <td>
                            <%= u.username %>
                        </td>
                        <td>
                            <%= u.name %>
                        </td>
                        <td>
                            <%= u.phone || '-' %>
                        </td>
                        <td><span class="badge badge-gray">
                                <%= u.role %>
                            </span></td>
                        <td>
                            <%= u.mill ? u.mill.name : 'All' %>
                        </td>
                        <td>
                            <span class="badge <%= u.is_active ? 'badge-green' : 'badge-red' %>">
                                <%= u.is_active ? 'Active' : 'Inactive' %>
                            </span>
                        </td>
                        <td>
                            <% if (u.username !=='admin' ) { %>
                                <div style="display: flex; gap: 5px;">
                                    <button onclick="openEditModal(<%= u.id %>, '<%= u.name.replace(/'/g, '\\\'') %>', '<%= u.phone || '' %>', '<%= u.role %>', <%= u.mill_id || 'null' %>, <%= u.accessible_mills ? '\'' + u.accessible_mills + '\'' : 'null' %>)"
                                        class="btn btn-sm btn-primary">
                                        Edit
                                    </button>
                                    <button onclick="toggleActive(<%= u.id %>, <%= !u.is_active %>)"
                                        class="btn btn-sm btn-secondary">
                                        <%= u.is_active ? 'Deactivate' : 'Activate' %>
                                    </button>
                                </div>
                                <% } %>
                        </td>
                    </tr>
                    <% }); %>
            </tbody>
        </table>
    </div>
</div>

<!-- Create User Modal -->
<div id="createUserModal"
    style="display: none; position: fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index: 100;">
    <div class="card" style="margin: 50px auto; max-width: 500px;">
        <h3>Create New User</h3>
        <form id="createUserForm">
            <div class="form-group">
                <label class="form-label">Username</label>
                <input type="text" name="username" class="form-control" required>
            </div>
            <div class="form-group">
                <label class="form-label">Password</label>
                <input type="password" name="password" class="form-control" required>
            </div>
            <div class="form-group">
                <label class="form-label">Full Name</label>
                <input type="text" name="name" class="form-control" required>
            </div>
            <div class="form-group">
                <label class="form-label">WhatsApp Number (e.g. 62812...)</label>
                <input type="text" name="phone" class="form-control" placeholder="628xxx">
            </div>
            <div class="form-group">
                <label class="form-label">Role</label>
                <select name="role" id="roleSelect" class="form-control" required onchange="toggleMillSelect()">
                    <option value="PROC">PROC (Processing)</option>
                    <option value="MTC">MTC (Maintenance)</option>
                    <option value="SPV">SPV (Supervisor)</option>
                    <option value="MANAGER">MANAGER</option>
                    <option value="SENIOR_MANAGER">SENIOR MANAGER</option>
                    <option value="OPERATOR">OPERATOR</option>
                    <option value="ADMIN">ADMIN</option>
                </select>
            </div>
            <div class="form-group" id="singleMillDiv">
                <label class="form-label">Mill</label>
                <select name="mill_id" id="millIdSelect" class="form-control">
                    <option value="">All Mills (Admin only)</option>
                    <% mills.forEach(m=> { %>
                        <option value="<%= m.id %>">
                            <%= m.name %>
                        </option>
                        <% }); %>
                </select>
            </div>

            <div class="form-group" id="multiMillDiv" style="display: none;">
                <label class="form-label">Accessible Mills (For Senior Manager)</label>
                <div style="max-height: 150px; overflow-y: auto; border: 1px solid #ccc; padding: 10px; border-radius: 4px;">
                    <% mills.forEach(m=> { %>
                        <label style="display: block; margin-bottom: 5px;">
                            <input type="checkbox" name="accessible_mills" value="<%= m.id %>"> <%= m.name %>
                        </label>
                    <% }); %>
                </div>
            </div>

            <div class="flex justify-between mt-4">
                <button type="button" onclick="closeModal('createUserModal')" class="btn btn-secondary">Cancel</button>
                <button type="submit" class="btn btn-primary">Create User</button>
            </div>
        </form>
    </div>
    </div>
</div>

<!-- Edit User Modal -->
<div id="editUserModal"
    style="display: none; position: fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index: 100;">
    <div class="card" style="margin: 50px auto; max-width: 500px;">
        <h3>Edit User</h3>
        <form id="editUserForm">
            <input type="hidden" name="id" id="editUserId">
            <div class="form-group">
                <label class="form-label">Full Name</label>
                <input type="text" name="name" id="editUserName" class="form-control" required>
            </div>
            <div class="form-group">
                <label class="form-label">WhatsApp Number (e.g. 62812...)</label>
                <input type="text" name="phone" id="editUserPhone" class="form-control" placeholder="628xxx">
            </div>
            <div class="form-group">
                <label class="form-label">Role</label>
                <select name="role" id="editUserRole" class="form-control" required onchange="toggleEditMillSelect()">
                    <option value="PROC">PROC (Processing)</option>
                    <option value="MTC">MTC (Maintenance)</option>
                    <option value="SPV">SPV (Supervisor)</option>
                    <option value="MANAGER">MANAGER</option>
                    <option value="SENIOR_MANAGER">SENIOR MANAGER</option>
                    <option value="OPERATOR">OPERATOR</option>
                    <option value="ADMIN">ADMIN</option>
                </select>
            </div>
            <div class="form-group" id="editSingleMillDiv">
                <label class="form-label">Mill</label>
                <select name="mill_id" id="editMillIdSelect" class="form-control">
                    <option value="">All Mills (Admin only)</option>
                    <% mills.forEach(m=> { %>
                        <option value="<%= m.id %>"><%= m.name %></option>
                    <% }); %>
                </select>
            </div>

            <div class="form-group" id="editMultiMillDiv" style="display: none;">
                <label class="form-label">Accessible Mills (For Senior Manager)</label>
                <div style="max-height: 150px; overflow-y: auto; border: 1px solid #ccc; padding: 10px; border-radius: 4px;">
                    <% mills.forEach(m=> { %>
                        <label style="display: block; margin-bottom: 5px;">
                            <input type="checkbox" name="accessible_mills" class="edit-mill-checkbox" value="<%= m.id %>"> <%= m.name %>
                        </label>
                    <% }); %>
                </div>
            </div>

            <div class="flex justify-between mt-4">
                <button type="button" onclick="closeModal('editUserModal')" class="btn btn-secondary">Cancel</button>
                <button type="submit" class="btn btn-primary">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openModal(id) { document.getElementById(id).style.display = 'block'; }
    function closeModal(id) { document.getElementById(id).style.display = 'none'; }

    async function toggleActive(id, isActive) {
        if (!confirm(`Are you sure you want to ${isActive ? 'activate' : 'deactivate'} this user?`)) return;

        try {
            const res = await fetch(`/api/users/${id}/active`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ is_active: isActive })
            });
            if (res.ok) window.location.reload();
            else alert('Error updating user');
        } catch (e) { console.error(e); }
    }

    function toggleMillSelect() {
        const role = document.getElementById('roleSelect').value;
        if (role === 'SENIOR_MANAGER') {
            document.getElementById('singleMillDiv').style.display = 'none';
            document.getElementById('millIdSelect').disabled = true;
            document.getElementById('multiMillDiv').style.display = 'block';
        } else {
            document.getElementById('singleMillDiv').style.display = 'block';
            document.getElementById('millIdSelect').disabled = false;
            document.getElementById('multiMillDiv').style.display = 'none';
        }
    }

    document.getElementById('createUserForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        
        // Handle multiple accessible_mills
        const accessibleMills = formData.getAll('accessible_mills').map(id => parseInt(id));
        formData.delete('accessible_mills');
        
        const data = Object.fromEntries(formData.entries());
        if (data.role === 'SENIOR_MANAGER') {
            data.accessible_mills = accessibleMills;
            data.mill_id = null; // Senior Managers don't use single mill_id
        }

        try {
            const res = await fetch('/api/users', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            if (res.ok) window.location.reload();
            else {
                const err = await res.json();
                alert('Error creating user: ' + err.error);
            }
        } catch (error) {
            console.error(error);
            alert('Error creating user');
        }
    });

    function toggleEditMillSelect() {
        const role = document.getElementById('editUserRole').value;
        if (role === 'SENIOR_MANAGER') {
            document.getElementById('editSingleMillDiv').style.display = 'none';
            document.getElementById('editMillIdSelect').disabled = true;
            document.getElementById('editMultiMillDiv').style.display = 'block';
        } else {
            document.getElementById('editSingleMillDiv').style.display = 'block';
            document.getElementById('editMillIdSelect').disabled = false;
            document.getElementById('editMultiMillDiv').style.display = 'none';
        }
    }

    function openEditModal(id, name, phone, role, mill_id, accessible_mills_json) {
        document.getElementById('editUserId').value = id;
        document.getElementById('editUserName').value = name || '';
        document.getElementById('editUserPhone').value = phone || '';
        document.getElementById('editUserRole').value = role || 'MTC';
        document.getElementById('editMillIdSelect').value = mill_id || '';
        
        // Reset checkboxes
        document.querySelectorAll('.edit-mill-checkbox').forEach(cb => cb.checked = false);
        
        // Check accessible_mills if exists
        if (accessible_mills_json) {
            try {
                const arr = JSON.parse(accessible_mills_json);
                if (Array.isArray(arr)) {
                    arr.forEach(mId => {
                        const cb = document.querySelector(`.edit-mill-checkbox[value="${mId}"]`);
                        if (cb) cb.checked = true;
                    });
                }
            } catch(e) { console.error('Error parsing accessible_mills', e); }
        }
        
        toggleEditMillSelect();
        openModal('editUserModal');
    }

    document.getElementById('editUserForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const id = document.getElementById('editUserId').value;
        const formData = new FormData(e.target);
        
        const accessibleMills = formData.getAll('accessible_mills').map(v => parseInt(v));
        formData.delete('accessible_mills');
        formData.delete('id');
        
        const data = Object.fromEntries(formData.entries());
        if (data.role === 'SENIOR_MANAGER') {
            data.accessible_mills = accessibleMills;
            data.mill_id = null;
        }

        try {
            const res = await fetch(`/api/users/${id}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            if (res.ok) window.location.reload();
            else {
                const err = await res.json();
                alert('Error updating user: ' + (err.error || 'Unknown error'));
            }
        } catch (error) {
            console.error(error);
            alert('Error updating user');
        }
    });
</script>