<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.0.0"></script>
<script>
    Chart.register(ChartDataLabels);
</script>

<div class="dashboard-grid mt-4"
    style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1rem;">
    <!-- Work Orders by Station Chart -->
    <div class="card" style="display: flex; flex-direction: column; align-items: center; justify-content: center;">
        <h3 style="width: 100%; text-align: left; font-size: 1rem; margin-bottom: 10px;"><i class="fas fa-chart-pie text-primary"></i> % WO per Station</h3>
        <% if (typeof stationChartData !== 'undefined' && stationChartData.data && stationChartData.data.length > 0) { %>
            <div style="width: 100%; height: 200px; position: relative;">
                <canvas id="stationWoChart"></canvas>
            </div>
        <% } else { %>
            <p class="text-secondary mt-3" style="text-align: center;">No data available for the selected filters.</p>
        <% } %>
    </div>
    <div class="card" style="display: flex; flex-direction: column; align-items: center; justify-content: center;">
        <h3 style="width: 100%; text-align: left; font-size: 1rem; margin-bottom: 10px;">WO by Type Kerusakan</h3>
        <div style="width: 100%; height: 200px; position: relative;">
            <canvas id="typeChart"></canvas>
        </div>
    </div>
    <div class="card" style="display: flex; flex-direction: column; align-items: center; justify-content: center;">
        <h3 style="width: 100%; text-align: left; font-size: 1rem; margin-bottom: 10px;">WO by Category</h3>
        <div style="width: 100%; height: 200px; position: relative;">
            <canvas id="categoryChart"></canvas>
        </div>
    </div>
    <!-- New Chart: WO Status Percentage -->
    <div class="card" style="display: flex; flex-direction: column; align-items: center; justify-content: center;">
        <h3 style="width: 100%; text-align: left; font-size: 1rem; margin-bottom: 10px;"><i class="fas fa-chart-pie" style="color: #10b981;"></i> % Status WO (Dari Tabel)</h3>
        <div style="width: 100%; height: 200px; position: relative;">
            <canvas id="statusTableChart"></canvas>
        </div>
    </div>
    <!-- New Chart: Duration -->
    <div class="card" style="display: flex; flex-direction: column; align-items: center; justify-content: center;">
        <h3 style="width: 100%; text-align: left; font-size: 1rem; margin-bottom: 10px;"><i class="fas fa-clock" style="color: #0f766e;"></i> Durasi Penyelesaian WO</h3>
        <div style="width: 100%; height: 200px; position: relative;">
            <canvas id="durationChart"></canvas>
        </div>
    </div>
    <!-- New Chart: Outstanding Duration -->
    <div class="card" style="display: flex; flex-direction: column; align-items: center; justify-content: center;">
        <h3 style="width: 100%; text-align: left; font-size: 1rem; margin-bottom: 10px;"><i class="fas fa-exclamation-circle" style="color: #ef4444;"></i> Durasi WO Outstanding</h3>
        <div style="width: 100%; height: 200px; position: relative;">
            <canvas id="outstandingDurationChart"></canvas>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        // Prepare Data from Server-Side
        const typeData = JSON.parse('<%- JSON.stringify(typeof typeStats !== "undefined" ? typeStats : []) %>');
        const categoryData = JSON.parse('<%- JSON.stringify(typeof categoryStats !== "undefined" ? categoryStats : []) %>');

        // Type Chart
        const typeLabels = typeData.map(d => d.type || 'Unknown');
        const typeCounts = typeData.map(d => d._count.type);
        const totalTypes = typeCounts.reduce((acc, curr) => acc + curr, 0);
        const typePercentages = typeCounts.map(count => totalTypes > 0 ? Math.round((count / totalTypes) * 100) : 0);

        new Chart(document.getElementById('typeChart'), {
            type: 'bar', // Using Bar chart for clarity
            plugins: [ChartDataLabels],
            data: {
                labels: typeLabels,
                datasets: [{
                    label: 'Percentage (%)',
                    data: typePercentages,
                    backgroundColor: 'rgba(54, 162, 235, 0.6)',
                    borderColor: 'rgba(54, 162, 235, 1)',
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: { 
                        beginAtZero: true, 
                        max: 100,
                        ticks: { 
                            stepSize: 20,
                            callback: function(value) {
                                return value + '%';
                            }
                        } 
                    }
                },
                plugins: {
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                const index = context.dataIndex;
                                return context.parsed.y + '% (' + typeCounts[index] + ' WO)';
                            }
                        }
                    },
                    datalabels: {
                        anchor: 'end',
                        align: 'end',
                        color: '#475569',
                        font: { weight: 'bold' },
                        formatter: function(value) {
                            return value > 0 ? value + '%' : '';
                        }
                    }
                }
            }
        });

        // Category Chart
        const catLabels = categoryData.map(d => d.category || 'Unknown');
        const catCounts = categoryData.map(d => d._count.category);

        new Chart(document.getElementById('categoryChart'), {
            type: 'doughnut', // Using Doughnut for category distribution
            plugins: [ChartDataLabels],
            data: {
                labels: catLabels,
                datasets: [{
                    data: catCounts,
                    backgroundColor: [
                        '#FF6384', '#36A2EB', '#FFCE56', '#4BC0C0', '#9966FF', '#FF9F40'
                    ]
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'right' },
                    datalabels: {
                        color: '#fff',
                        font: { weight: 'bold', size: 11 },
                        formatter: (value, ctx) => {
                            if (value === 0) return '';
                            let sum = 0;
                            let dataArr = ctx.chart.data.datasets[0].data;
                            dataArr.forEach(data => sum += data);
                            return Math.round((value / sum) * 100) + "%";
                        }
                    }
                }
            }
        });

        // Status Table Chart
        const mtData = JSON.parse('<%- JSON.stringify(typeof maintenanceTable !== "undefined" ? maintenanceTable : null) %>');
        const ptData = JSON.parse('<%- JSON.stringify(typeof processingTable !== "undefined" ? processingTable : null) %>');

        let totalOpen = 0, totalInProgress = 0, totalCompleteClose = 0, totalAssigned = 0, totalOnHold = 0;

        if (mtData) {
            ['hmBase', 'autoPm', 'mechCivilEtc', 'electInst'].forEach(key => {
                if(mtData[key]) {
                    totalOpen += mtData[key].open || 0;
                    totalInProgress += mtData[key].inProgress || 0;
                    totalCompleteClose += mtData[key].completeClose || 0;
                    totalAssigned += mtData[key].assigned || 0;
                    totalOnHold += mtData[key].onHold || 0;
                }
            });
        }

        if (ptData && ptData.manualProcessing) {
            totalOpen += ptData.manualProcessing.open || 0;
            totalInProgress += ptData.manualProcessing.inProgress || 0;
            totalCompleteClose += ptData.manualProcessing.completeClose || 0;
            totalAssigned += ptData.manualProcessing.assigned || 0;
            totalOnHold += ptData.manualProcessing.onHold || 0;
        }

        const statusLabels = ['OPEN', 'IN PROGRESS', 'COMPLETE & CLOSE', 'ASSIGNED', 'ON HOLD'];
        const statusData = [totalOpen, totalInProgress, totalCompleteClose, totalAssigned, totalOnHold];
        const hasStatusData = statusData.some(val => val > 0);

        const statusDetailsData = JSON.parse('<%- JSON.stringify(typeof statusTableDetails !== "undefined" ? statusTableDetails : null) %>');

        if(hasStatusData && document.getElementById('statusTableChart')) {
            new Chart(document.getElementById('statusTableChart'), {
                type: 'doughnut',
                plugins: [ChartDataLabels],
                data: {
                    labels: statusLabels,
                    datasets: [{
                        data: statusData,
                        backgroundColor: ['#3b82f6', '#f59e0b', '#10b981', '#8b5cf6', '#64748b']
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'right' },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    const index = context.dataIndex;
                                    const count = statusData[index];
                                    let sum = 0;
                                    statusData.forEach(data => sum += data);
                                    const percentage = sum > 0 ? Math.round((count / sum) * 100) : 0;
                                    
                                    let lines = [percentage + '% (' + count + ' WO)'];
                                    
                                    if (statusDetailsData) {
                                        const keys = ['open', 'inProgress', 'completeClose', 'assigned', 'onHold'];
                                        const key = keys[index];
                                        const details = statusDetailsData[key];
                                        if (details && Object.keys(details).length > 0) {
                                            lines.push('--- Detail ---');
                                            Object.keys(details).forEach(cat => {
                                                lines.push(details[cat] + ' ' + cat);
                                            });
                                        }
                                    }
                                    return lines;
                                }
                            }
                        },
                        datalabels: {
                            color: '#fff',
                            font: { weight: 'bold', size: 11 },
                            formatter: (value, ctx) => {
                                if (value === 0) return '';
                                let sum = 0;
                                let dataArr = ctx.chart.data.datasets[0].data;
                                dataArr.forEach(data => sum += data);
                                return Math.round((value / sum) * 100) + "%";
                            }
                        }
                    }
                }
            });
        }

        // Duration Chart
        const durData = JSON.parse('<%- JSON.stringify(typeof durationTable !== "undefined" ? durationTable : null) %>');
        const durDetailsData = JSON.parse('<%- JSON.stringify(typeof durationDetails !== "undefined" ? durationDetails : null) %>');
        
        if (durData) {
            const durLabels = ['< 3 Hari', '4-7 Hari', '8-14 Hari', '> 14 Hari'];
            const durCounts = [durData.under3 || 0, durData.days4to7 || 0, durData.days8to14 || 0, durData.over14 || 0];
            const totalDur = durCounts.reduce((acc, curr) => acc + curr, 0);
            const durPercentages = durCounts.map(count => totalDur > 0 ? Math.round((count / totalDur) * 100) : 0);
            const hasDurData = durCounts.some(val => val > 0);

            if (hasDurData && document.getElementById('durationChart')) {
                new Chart(document.getElementById('durationChart'), {
                    type: 'bar',
                    plugins: [ChartDataLabels],
                    data: {
                        labels: durLabels,
                        datasets: [{
                            label: 'Percentage (%)',
                            data: durPercentages,
                            backgroundColor: [
                                '#10b981', // green
                                '#f59e0b', // yellow
                                '#f97316', // orange
                                '#ef4444'  // red
                            ],
                            borderWidth: 0,
                            borderRadius: 4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: { 
                                beginAtZero: true,
                                max: 100,
                                ticks: { 
                                    stepSize: 20,
                                    callback: function(value) {
                                        return value + '%';
                                    }
                                } 
                            }
                        },
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        const index = context.dataIndex;
                                        let lines = [context.parsed.y + '% (' + durCounts[index] + ' WO)'];
                                        
                                        if (durDetailsData) {
                                            const keys = ['under3', 'days4to7', 'days8to14', 'over14'];
                                            const key = keys[index];
                                            const details = durDetailsData[key];
                                            if (details && Object.keys(details).length > 0) {
                                                lines.push('--- Detail ---');
                                                Object.keys(details).forEach(cat => {
                                                    lines.push(details[cat] + ' ' + cat);
                                                });
                                            }
                                        }
                                        return lines;
                                    }
                                }
                            },
                            datalabels: {
                                anchor: 'end',
                                align: 'end',
                                color: '#475569',
                                font: { weight: 'bold' },
                                formatter: function(value) {
                                    return value > 0 ? value + '%' : '';
                                }
                            }
                        }
                    }
                });
            }
        }

        // Outstanding Duration Chart
        const outDurData = JSON.parse('<%- JSON.stringify(typeof outstandingDurationTable !== "undefined" ? outstandingDurationTable : null) %>');
        const outDurDetailsData = JSON.parse('<%- JSON.stringify(typeof outstandingDurationDetails !== "undefined" ? outstandingDurationDetails : null) %>');
        
        if (outDurData) {
            const outDurLabels = ['< 3 Hari', '4-7 Hari', '8-14 Hari', '> 15 Hari'];
            const outDurCounts = [outDurData.under3 || 0, outDurData.days4to7 || 0, outDurData.days8to14 || 0, outDurData.over14 || 0];
            const totalOutDur = outDurCounts.reduce((acc, curr) => acc + curr, 0);
            const outDurPercentages = outDurCounts.map(count => totalOutDur > 0 ? Math.round((count / totalOutDur) * 100) : 0);
            const hasOutDurData = outDurCounts.some(val => val > 0);

            if (hasOutDurData && document.getElementById('outstandingDurationChart')) {
                new Chart(document.getElementById('outstandingDurationChart'), {
                    type: 'bar',
                    plugins: [ChartDataLabels],
                    data: {
                        labels: outDurLabels,
                        datasets: [{
                            label: 'Percentage (%)',
                            data: outDurPercentages,
                            backgroundColor: [
                                '#10b981', // green
                                '#f59e0b', // yellow
                                '#f97316', // orange
                                '#ef4444'  // red
                            ],
                            borderWidth: 0,
                            borderRadius: 4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: { 
                                beginAtZero: true,
                                max: 100,
                                ticks: { 
                                    stepSize: 20,
                                    callback: function(value) {
                                        return value + '%';
                                    }
                                } 
                            }
                        },
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        const index = context.dataIndex;
                                        let lines = [context.parsed.y + '% (' + outDurCounts[index] + ' WO)'];
                                        
                                        if (outDurDetailsData) {
                                            const keys = ['under3', 'days4to7', 'days8to14', 'over14'];
                                            const key = keys[index];
                                            const details = outDurDetailsData[key];
                                            if (details && Object.keys(details).length > 0) {
                                                lines.push('--- Detail ---');
                                                Object.keys(details).forEach(cat => {
                                                    lines.push(details[cat] + ' ' + cat);
                                                });
                                            }
                                        }
                                        return lines;
                                    }
                                }
                            },
                            datalabels: {
                                anchor: 'end',
                                align: 'end',
                                color: '#475569',
                                font: { weight: 'bold' },
                                formatter: function(value) {
                                    return value > 0 ? value + '%' : '';
                                }
                            }
                        }
                    }
                });
            }
        }

        if (typeof hasDurData !== 'undefined' && !hasDurData && document.getElementById('durationChart')) {
            const canvas = document.getElementById('durationChart');
            canvas.parentElement.innerHTML = '<p class="text-secondary mt-3" style="text-align: center;">Belum ada data durasi penyelesaian WO.</p>';
        }

        if (typeof hasOutDurData !== 'undefined' && !hasOutDurData && document.getElementById('outstandingDurationChart')) {
            const canvas = document.getElementById('outstandingDurationChart');
            canvas.parentElement.innerHTML = '<p class="text-secondary mt-3" style="text-align: center;">Belum ada data durasi WO Outstanding.</p>';
        }
    });
</script>

        <div class="card mt-4">

            <div class="flex justify-between items-center mb-4">
                <h3>Work Orders <%= typeof hasFilters !=='undefined' && hasFilters ? '(Filtered)' : '(Recent)' %>
                </h3>
                <div>
                    <button onclick="openPrintModal()" class="btn btn-primary btn-sm" style="margin-right: 5px;">
                        <i class="fas fa-print"></i> Print Rekap
                    </button>
                    <a href="/work-orders" class="btn btn-secondary btn-sm">View All</a>
                </div>
            </div>

            <!-- Dashboard Filters -->
            <div class="card mb-4" style="background-color: #f8f9fa; border: 1px solid #e9ecef;">
                <form action="/dashboard" method="GET" id="dashboardFilterForm">
                    <% if (typeof selectedMillId !=='undefined' && selectedMillId) { %>
                        <input type="hidden" name="millId" value="<%= selectedMillId %>">
                        <% } %>

                            <div
                                style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; align-items: end;">

                                <!-- Date Range Column -->
                                <div style="min-width: 250px;">
                                    <label
                                        style="display: block; margin-bottom: 8px; font-weight: 600; font-size: 0.9em; color: #495057;">Date
                                        Range</label>
                                    <div style="display: flex; gap: 8px; align-items: center;">
                                        <input type="date" name="startDate" class="form-control"
                                            style="font-size: 0.9em;"
                                            value="<%= typeof filterInfo !== 'undefined' && filterInfo.startDate ? new Date(filterInfo.startDate).toISOString().split('T')[0] : '' %>">
                                        <span style="color: #6c757d;">-</span>
                                        <input type="date" name="endDate" class="form-control" style="font-size: 0.9em;"
                                            value="<%= typeof filterInfo !== 'undefined' && filterInfo.endDate ? new Date(filterInfo.endDate).toISOString().split('T')[0] : '' %>">
                                    </div>
                                </div>

                                <!-- Status Column -->
                                <div style="flex-grow: 2;">
                                    <label
                                        style="display: block; margin-bottom: 8px; font-weight: 600; font-size: 0.9em; color: #495057;">Status</label>
                                    <div
                                        style="display: grid; grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); gap: 8px;">
                                        <% ['OPEN', 'ASSIGNED' , 'IN_PROGRESS' , 'ON_HOLD' , 'COMPLETED' , 'CLOSED'
                                            ].forEach(status=> { %>
                                            <label
                                                style="font-size: 0.85em; display: flex; align-items: center; gap: 6px; cursor: pointer; white-space: nowrap;">
                                                <input type="checkbox" name="status" value="<%= status %>" <%=typeof
                                                    filterInfo !=='undefined' && filterInfo.status &&
                                                    (Array.isArray(filterInfo.status) ?
                                                    filterInfo.status.includes(status) : filterInfo.status===status)
                                                    ? 'checked' : '' %>>
                                                <%= status %>
                                            </label>
                                            <% }); %>
                                    </div>
                                </div>

                                <!-- Actions Column -->
                                <div style="display: flex; gap: 8px; justify-content: flex-end;">
                                    <button type="submit" class="btn btn-primary btn-sm"
                                        style="display: flex; align-items: center; gap: 5px;">
                                        <i class="fas fa-filter"></i> Apply
                                    </button>
                                    <% if (typeof hasFilters !=='undefined' && hasFilters) { %>
                                        <a href="/dashboard<%= typeof selectedMillId !== 'undefined' ? '?millId=' + selectedMillId : '' %>"
                                            class="btn btn-secondary btn-sm"
                                            style="display: flex; align-items: center; gap: 5px;">
                                            <i class="fas fa-times"></i> Clear
                                        </a>
                                        <% } %>
                                </div>
                            </div>
                </form>
            </div>


            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>WO No & Desc</th>
                            <th>Station</th>
                            <th>PIC Role</th>
                            <th>Tgl Permintaan</th>
                            <th>Actual Complete</th>
                            <th>Status</th>
                            <% if (user.role === 'ADMIN') { %>
                            <th>Actions</th>
                            <% } %>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (typeof recentWos !=='undefined' && recentWos.length> 0) { %>
                            <% recentWos.forEach(wo=> { %>
                                <tr>
                                    <td>
                                        <a href="/work-orders/<%= wo.id %>?readonly=true" style="color: var(--primary-color); font-weight: 600; text-decoration: none;">
                                            <%= wo.wo_no %>
                                        </a>
                                        <div style="font-size: 0.85em; color: #64748b; margin-top: 2px;"><%= wo.description %></div>
                                    </td>
                                    <td>
                                        <%= wo.station.name %>
                                    </td>
                                    <td>
                                        <% if (wo.pics && wo.pics.length > 0) { %>
                                            <%= wo.pics.map(p => p.name).join(', ') %>
                                        <% } else if (wo.assignee) { %>
                                            <%= wo.assignee.name %> <span style="font-size: 0.8em; color: #64748b;">(<%= wo.assignee.role %>)</span>
                                        <% } else { %>
                                            <span class="text-secondary">-</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <%= new Date(wo.created_at).toLocaleDateString('id-ID', {day: '2-digit', month: 'short', year: 'numeric'}) %>
                                    </td>
                                    <td>
                                        <% if (wo.closed_at || wo.completed_at) { %>
                                            <%= new Date(wo.closed_at || wo.completed_at).toLocaleDateString('id-ID', {day: '2-digit', month: 'short', year: 'numeric'}) %>
                                        <% } else { %>
                                            <span class="text-secondary">-</span>
                                        <% } %>
                                    </td>
                                    <td><span class="badge status-<%= wo.status %>">
                                            <%= wo.status %>
                                        </span></td>
                                    <% if (user.role === 'ADMIN') { %>
                                        <td>
                                            <% if (wo.status !== 'COMPLETED' && wo.status !== 'CLOSED') { %>
                                                <button class="btn btn-sm" style="background-color: #dc3545; color: white; border: none; padding: 4px 8px; border-radius: 4px; cursor: pointer;" onclick="deleteWo(event, '<%= wo.id %>', '<%= wo.wo_no %>')">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            <% } else { %>
                                                <span class="text-secondary" style="font-size: 0.8em;">-</span>
                                            <% } %>
                                        </td>
                                    <% } %>
                                </tr>
                                <% }); %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="7" class="text-center">No recent work orders found.</td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Print Filter Modal -->
        <div id="printModal" class="modal-overlay"
            style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center;">
            <div class="modal-content"
                style="background: white; padding: 20px; border-radius: 8px; width: 400px; max-width: 90%;">
                <h3 style="margin-top: 0;">Print Filters</h3>
                <form action="/dashboard/print" method="GET" target="_blank">
                    <!-- Persist Mill ID if exists -->
                    <% if (typeof selectedMillId !=='undefined' && selectedMillId) { %>
                        <input type="hidden" name="millId" value="<%= selectedMillId %>">
                        <% } %>

                            <div style="margin-bottom: 15px;">
                                <label style="display: block; margin-bottom: 5px; font-weight: bold;">Date Range</label>
                                <div style="display: flex; gap: 10px;">
                                    <input type="date" name="startDate" class="form-control" style="flex: 1;"
                                        value="<%= typeof filterInfo !== 'undefined' && filterInfo.startDate ? new Date(filterInfo.startDate).toISOString().split('T')[0] : '' %>">
                                    <input type="date" name="endDate" class="form-control" style="flex: 1;"
                                        value="<%= typeof filterInfo !== 'undefined' && filterInfo.endDate ? new Date(filterInfo.endDate).toISOString().split('T')[0] : '' %>">
                                </div>
                            </div>

                            <div style="margin-bottom: 15px;">
                                <label style="display: block; margin-bottom: 5px; font-weight: bold;">Status</label>
                                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 5px;">
                                    <% ['OPEN', 'ASSIGNED' , 'IN_PROGRESS' , 'ON_HOLD' , 'COMPLETED' , 'CLOSED'
                                        ].forEach(status=> { %>
                                        <label><input type="checkbox" name="status" value="<%= status %>" <%=typeof
                                                filterInfo !=='undefined' && filterInfo.status &&
                                                (Array.isArray(filterInfo.status) ? filterInfo.status.includes(status) :
                                                filterInfo.status===status) ? 'checked' : '' %>> <%= status %></label>
                                        <% }); %>
                                </div>
                            </div>

                            <div style="margin-bottom: 15px;">
                                <label style="display: block; margin-bottom: 5px; font-weight: bold;">Type / Category</label>
                                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 5px;">
                                    <% ['Mechanical', 'Electrical', 'Instrument', 'Civil', 'Utility', 'Fabrication', 'Processing', 'Others'].forEach(cat=> { %>
                                        <label><input type="checkbox" name="category" value="<%= cat %>" <%=typeof
                                                filterInfo !=='undefined' && filterInfo.category &&
                                                (Array.isArray(filterInfo.category) ? filterInfo.category.includes(cat) :
                                                filterInfo.category===cat) ? 'checked' : '' %>> <%= cat %></label>
                                    <% }); %>
                                </div>
                            </div>

                            <div style="text-align: right; margin-top: 20px;">
                                <button type="button" onclick="closePrintModal()" class="btn btn-secondary"
                                    style="margin-right: 5px;">Cancel</button>
                                <button type="submit" class="btn btn-primary" onclick="closePrintModal()">Print</button>
                            </div>
                </form>
            </div>
        </div>

        <script>
            function openPrintModal() {
                document.getElementById('printModal').style.display = 'flex';
            }
            function closePrintModal() {
                document.getElementById('printModal').style.display = 'none';
            }

            // Close modal when clicking outside
            document.getElementById('printModal').addEventListener('click', function (e) {
                if (e.target === this) {
                    closePrintModal();
                }
            });

            async function deleteWo(e, id, woNo) {
                e.stopPropagation(); // prevent row click from opening details
                if (!confirm(`Yakin ingin MENGHAPUS Work Order ${woNo} secara permanen?\nWork Order yang belum selesai ini akan lenyap dari sistem.`)) return;
                
                try {
                    const btn = e.target.closest('button');
                    btn.disabled = true;
                    btn.innerHTML = 'Hapus...';

                    const res = await fetch('/api/work-orders/' + id, { method: 'DELETE' });
                    if (res.ok) {
                        alert('Work Order berhasil dihapus!');
                        window.location.reload();
                    } else {
                        const data = await res.json();
                        alert('Gagal menghapus: ' + (data.error || 'Unknown error'));
                        btn.disabled = false;
                        btn.innerHTML = '<i class="fas fa-trash"></i> Hapus';
                    }
                } catch (err) {
                    console.error(err);
                    alert('Terjadi kesalahan koneksi/server.');
                }
            }
        </script>

        <!-- Chart.js and Initialization -->
        <% if (typeof stationChartData !== 'undefined' && stationChartData.data && stationChartData.data.length > 0) { %>
            <script>
                document.addEventListener("DOMContentLoaded", function () {
                    const ctx = document.getElementById('stationWoChart');
                    if (ctx) {
                        new Chart(ctx, {
                            type: 'doughnut',
                            plugins: [ChartDataLabels],
                            data: {
                                labels: <%- JSON.stringify(stationChartData.labels) %>,
                                datasets: [{
                                    data: <%- JSON.stringify(stationChartData.data) %>,
                                    backgroundColor: [
                                        '#3b82f6', '#10b981', '#ef4444', '#f59e0b', '#8b5cf6',
                                        '#06b6d4', '#ec4899', '#f97316', '#14b8a6', '#64748b',
                                        '#84cc16', '#6366f1', '#d946ef', '#f43f5e', '#0ea5e9'
                                    ],
                                    borderWidth: 1
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                plugins: {
                                    datalabels: {
                                        color: '#fff',
                                        font: { weight: 'bold', size: 12 },
                                        formatter: (value, ctx) => {
                                            if (value === 0) return '';
                                            let sum = 0;
                                            let dataArr = ctx.chart.data.datasets[0].data;
                                            dataArr.forEach(data => sum += data);
                                            return Math.round((value / sum) * 100) + "%";
                                        }
                                    },
                                    legend: {
                                        position: 'right',
                                        labels: {
                                            boxWidth: 12
                                        }
                                    },
                                    tooltip: {
                                        callbacks: {
                                            label: function(context) {
                                                let label = context.label || '';
                                                if (label) {
                                                    label += ': ';
                                                }
                                                const total = context.chart._metasets[context.datasetIndex].total;
                                                const value = context.raw;
                                                const percentage = Math.round((value / total) * 100) + '%';
                                                return label + value + ' WO (' + percentage + ')';
                                            }
                                        }
                                    }
                                }
                            }
                        });
                    }
                });
            </script>
        <% } %>