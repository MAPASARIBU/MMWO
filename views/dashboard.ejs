<div class="dashboard-grid"
    style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem;">
    <div class="card">
        <h3>My Pending Tasks</h3>
        <% if ((user.role==='ADMIN' || user.role==='SENIOR_MANAGER') && typeof mills !=='undefined' && mills.length> 0) { %>
            <div style="margin-bottom: 10px;">
                <select onchange="window.location.href='/dashboard?millId='+this.value" class="form-control"
                    style="width: 100%;">
                    <option value="">-- All Mills --</option>
                    <% mills.forEach(mill=> { %>
                        <option value="<%= mill.id %>" <%=typeof selectedMillId !=='undefined' &&
                            selectedMillId===mill.id ? 'selected' : '' %>>
                            <%= mill.name %>
                        </option>
                        <% }); %>
                </select>
            </div>
            <% } %>
                <p class="text-3xl font-bold mt-2"
                    style="font-size: 2rem; font-weight: 700; color: var(--primary-color);">
                    <%= typeof stats !=='undefined' ? stats.pending : '-' %>
                </p>
    </div>
    <div class="card">
        <h3>Completion Rate</h3>
        <p class="text-3xl font-bold mt-2" style="font-size: 2rem; font-weight: 700; color: var(--success-color);">
            <%= typeof stats !=='undefined' ? stats.completionRate + '%' : '-' %>
        </p>
    </div>
    <div class="card">
        <h3>High Priority (P1)</h3>
        <p class="text-3xl font-bold mt-2" style="font-size: 2rem; font-weight: 700; color: var(--danger-color);">
            <%= typeof stats !=='undefined' ? stats.highPriority : '-' %>
        </p>
    </div>
</div>

</div>

<!-- Dashboard Monitoring Tables (Requested by User) -->
<% if (typeof maintenanceTable !== 'undefined') { %>
<div class="card mt-4">
    <div class="flex justify-between items-center mb-4">
        <h3><i class="fas fa-tools"></i> A. MAINTENANCE WEEKLY PLANT</h3>
    </div>
    <div class="table-responsive" style="overflow-x: auto;">
        <table class="table text-center" style="margin-bottom: 0; width: 100%; border-collapse: collapse; font-size: 0.85em;">
            <thead style="background-color: #f8fafc; color: #475569; border-bottom: 2px solid #e2e8f0;">
                <tr>
                    <th style="text-align: left; padding: 8px 12px; width: 28%; font-weight: 600;">TYPE WO</th>
                    <th style="padding: 8px; width: 12%; font-weight: 600;">TOTAL WO</th>
                    <th style="padding: 8px; width: 12%; font-weight: 600; color: #3b82f6;">OPEN</th>
                    <th style="padding: 8px; width: 12%; font-weight: 600; color: #f59e0b;">IN PROGRESS</th>
                    <th style="padding: 8px; width: 12%; font-weight: 600; color: #10b981;">COMPLETE & CLOSE</th>
                    <th style="padding: 8px; width: 12%; font-weight: 600; color: #8b5cf6;">ASSIGNED</th>
                    <th style="padding: 8px; width: 12%; font-weight: 600; color: #64748b;">ON HOLD</th>
                </tr>
            </thead>
            <tbody>
                <tr style="border-bottom: 1px solid #f1f5f9;">
                    <td style="text-align: left; padding: 8px 12px; font-weight: 500; color: #334155;">WO PENGANTIAN PART (HM BASE)</td>
                    <td style="padding: 8px; font-weight: 600;"><%= maintenanceTable.hmBase.total %></td>
                    <td style="padding: 8px;"><%= maintenanceTable.hmBase.open %></td>
                    <td style="padding: 8px;"><%= maintenanceTable.hmBase.inProgress %></td>
                    <td style="padding: 8px;"><%= maintenanceTable.hmBase.completeClose %></td>
                    <td style="padding: 8px;"><%= maintenanceTable.hmBase.assigned %></td>
                    <td style="padding: 8px;"><%= maintenanceTable.hmBase.onHold %></td>
                </tr>
                <tr style="border-bottom: 1px solid #f1f5f9; background-color: #fcfcfc;">
                    <td style="text-align: left; padding: 8px 12px; font-weight: 500; color: #334155;">AUTO PM (TIME BASE)</td>
                    <td style="padding: 8px; font-weight: 600;"><%= maintenanceTable.autoPm.total %></td>
                    <td style="padding: 8px;"><%= maintenanceTable.autoPm.open %></td>
                    <td style="padding: 8px;"><%= maintenanceTable.autoPm.inProgress %></td>
                    <td style="padding: 8px;"><%= maintenanceTable.autoPm.completeClose %></td>
                    <td style="padding: 8px;"><%= maintenanceTable.autoPm.assigned %></td>
                    <td style="padding: 8px;"><%= maintenanceTable.autoPm.onHold %></td>
                </tr>
                <tr style="border-bottom: 1px solid #f1f5f9;">
                    <td style="text-align: left; padding: 8px 12px; font-weight: 500; color: #334155;">WO (MECHANICAL, UTILITY, OTHER, CIVIL, FAB)</td>
                    <td style="padding: 8px; font-weight: 600;"><%= maintenanceTable.mechCivilEtc.total %></td>
                    <td style="padding: 8px;"><%= maintenanceTable.mechCivilEtc.open %></td>
                    <td style="padding: 8px;"><%= maintenanceTable.mechCivilEtc.inProgress %></td>
                    <td style="padding: 8px;"><%= maintenanceTable.mechCivilEtc.completeClose %></td>
                    <td style="padding: 8px;"><%= maintenanceTable.mechCivilEtc.assigned %></td>
                    <td style="padding: 8px;"><%= maintenanceTable.mechCivilEtc.onHold %></td>
                </tr>
                <tr>
                    <td style="text-align: left; padding: 8px 12px; font-weight: 500; color: #334155;">WO (ELECTRICAL, INSTRUMENT)</td>
                    <td style="padding: 8px; font-weight: 600;"><%= maintenanceTable.electInst.total %></td>
                    <td style="padding: 8px;"><%= maintenanceTable.electInst.open %></td>
                    <td style="padding: 8px;"><%= maintenanceTable.electInst.inProgress %></td>
                    <td style="padding: 8px;"><%= maintenanceTable.electInst.completeClose %></td>
                    <td style="padding: 8px;"><%= maintenanceTable.electInst.assigned %></td>
                    <td style="padding: 8px;"><%= maintenanceTable.electInst.onHold %></td>
                </tr>
                <tr style="border-top: 2px solid #e2e8f0; background-color: #f8fafc; font-weight: bold;">
                    <td style="text-align: left; padding: 8px 12px; color: #334155;">TOTAL</td>
                    <td style="padding: 8px;"><%= maintenanceTable.hmBase.total + maintenanceTable.autoPm.total + maintenanceTable.mechCivilEtc.total + maintenanceTable.electInst.total %></td>
                    <td style="padding: 8px; color: #3b82f6;"><%= maintenanceTable.hmBase.open + maintenanceTable.autoPm.open + maintenanceTable.mechCivilEtc.open + maintenanceTable.electInst.open %></td>
                    <td style="padding: 8px; color: #f59e0b;"><%= maintenanceTable.hmBase.inProgress + maintenanceTable.autoPm.inProgress + maintenanceTable.mechCivilEtc.inProgress + maintenanceTable.electInst.inProgress %></td>
                    <td style="padding: 8px; color: #10b981;"><%= maintenanceTable.hmBase.completeClose + maintenanceTable.autoPm.completeClose + maintenanceTable.mechCivilEtc.completeClose + maintenanceTable.electInst.completeClose %></td>
                    <td style="padding: 8px; color: #8b5cf6;"><%= maintenanceTable.hmBase.assigned + maintenanceTable.autoPm.assigned + maintenanceTable.mechCivilEtc.assigned + maintenanceTable.electInst.assigned %></td>
                    <td style="padding: 8px; color: #64748b;"><%= maintenanceTable.hmBase.onHold + maintenanceTable.autoPm.onHold + maintenanceTable.mechCivilEtc.onHold + maintenanceTable.electInst.onHold %></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
<% } %>

