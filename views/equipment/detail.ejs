<div class="card mb-4">
    <div class="flex justify-between items-center">
        <div>
            <h2 class="mb-0"><%= equipment.name %></h2>
            <p class="text-secondary mb-0">Code: <%= equipment.code %> | Station: <%= equipment.station.name %> | Mill: <%= equipment.station.mill.name %></p>
        </div>
        <div>
            <% if (user && (user.role === 'ADMIN' || user.role === 'MTC')) { %>
                <button class="btn btn-primary" onclick="openModal('addPartModal')">+ Add New Part</button>
            <% } %>
            <button class="btn btn-secondary" onclick="openModal('recordHmModal')">Record HM</button>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <!-- Parts List -->
    <div class="card">
        <h3>Spareparts Monitoring</h3>
        <% const activeParts = equipment.parts.filter(p => p.is_active); %>
        <% if(activeParts.length === 0) { %>
            <p class="text-secondary">No active parts recorded yet.</p>
        <% } else { %>
            <div class="mt-4">
                <% activeParts.forEach(part => { 
                    const percent = Math.min(100, (part.current_hm / part.lifetime_hm) * 100);
                    let color = 'bg-success'; // Green
                    let statusText = 'Normal';
                    if (percent >= 100) { color = 'bg-danger'; statusText = 'Critical - Ganti Segera'; }
                    else if (percent >= 90) { color = 'bg-warning'; statusText = 'Warning - Persiapan Ganti'; }
                %>
                <div class="mb-4 p-3 border rounded bg-white">
                    <div class="flex justify-between items-center mb-2">
                        <strong class="text-lg"><%= part.name %></strong>
                        <div>
                            <button class="btn btn-sm btn-outline-primary" onclick="openReplaceModal(<%= part.id %>, '<%= part.name %>', <%= part.lifetime_hm %>)">Replace</button>
                            <% if(user && user.role === 'ADMIN') { %>
                                <button class="btn btn-sm btn-outline-secondary" onclick="openEditPartModal(<%= part.id %>, '<%= part.name %>', <%= part.lifetime_hm %>, <%= part.current_hm %>)" style="margin-left: 5px;" title="Edit Part"><i class="fas fa-edit"></i></button>
                                <button class="btn btn-sm btn-outline-danger" onclick="deletePart(<%= part.id %>)" style="margin-left: 5px;" title="Delete Part"><i class="fas fa-trash"></i></button>
                            <% } %>
                        </div>
                    </div>
                    
                    <div class="flex justify-between text-sm mb-1">
                        <span>Current HM: <b><%= part.current_hm %></b> / <%= part.lifetime_hm %></span>
                        <span class="font-bold <%= percent>=90?'text-danger':'' %>"><%= statusText %> (<%= percent.toFixed(1) %>%)</span>
                    </div>
                    
                    <div style="height: 10px; background: #eee; border-radius: 5px; overflow: hidden; width: 100%;">
                        <div style="height: 100%; width: <%= percent %>%; background-color: <%= percent>=100?'#ef4444':percent>=90?'#f59e0b':'#10b981' %>;"></div>
                    </div>
                    <div class="text-xs text-secondary mt-1">Installed: <%= part.installed_at.toLocaleDateString() %></div>
                </div>
                <% }); %>
            </div>
        <% } %>
    </div>

    <!-- HM History -->
    <div class="card">
        <h3>Recent HM Records</h3>
        <% if(equipment.hm_records.length === 0) { %>
            <p class="text-secondary">No HM records yet.</p>
        <% } else { %>
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Operation HM</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% equipment.hm_records.forEach(record => { %>
                            <tr>
                                <td><%= record.record_date.toLocaleDateString() %></td>
                                <td><span class="badge" style="background: #e0e7ff; color: #3730a3;">+ <%= record.hm_value %> HM</span></td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </div>
</div>

<div class="card mt-4">
    <div class="flex justify-between items-center mb-4">
        <h3>Periodic Preventive Maintenance (Time-Based)</h3>
        <% if (user && (user.role === 'ADMIN' || user.role === 'MTC' || user.role === 'PROC')) { %>
            <button class="btn btn-primary" onclick="openModal('addPeriodicPMModal')">+ Add PM Plan</button>
        <% } %>
    </div>
    <% if(!equipment.periodic_pms || equipment.periodic_pms.length === 0) { %>
        <p class="text-secondary">No periodic maintenance plans configured.</p>
    <% } else { %>
        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Plan Name</th>
                        <th>Interval</th>
                        <th>Next Due Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% equipment.periodic_pms.forEach(pm => { 
                        const isDueSoon = new Date(pm.next_due_date).getTime() - new Date().getTime() <= (7 * 24 * 60 * 60 * 1000); // 7 days
                        const isOverdue = new Date(pm.next_due_date).getTime() < new Date().getTime();
                        let badgeColor = isOverdue ? 'bg-danger text-white' : (isDueSoon ? 'bg-warning text-dark' : 'bg-success text-white');
                    %>
                    <tr>
                        <td><strong><%= pm.name %></strong></td>
                        <td>Every <%= pm.interval_value %> <%= pm.interval_type %>(s)</td>
                        <td>
                            <span class="badge <%= badgeColor %>">
                                <%= new Date(pm.next_due_date).toLocaleDateString() %>
                            </span>
                        </td>
                        <td>
                            <span class="badge <%= pm.is_active ? 'bg-primary' : 'bg-secondary' %>">
                                <%= pm.is_active ? 'Active' : 'Inactive' %>
                            </span>
                        </td>
                        <td>
                            <% if(user && (user.role === 'ADMIN' || user.role === 'MTC' || user.role === 'PROC')) { %>
                                <button class="btn btn-sm btn-outline-secondary" onclick="openEditPMModal(<%= pm.id %>, '<%= pm.name %>', '<%= pm.interval_type %>', <%= pm.interval_value %>, '<%= new Date(pm.next_due_date).toISOString().slice(0,10) %>')" title="Edit"><i class="fas fa-edit"></i> Edit</button>
                                <button class="btn btn-sm btn-outline-danger" onclick="deletePeriodicPM(<%= pm.id %>)" title="Delete"><i class="fas fa-trash"></i></button>
                            <% } %>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    <% } %>
</div>

<!-- Add Part Modal -->
<div id="addPartModal" style="display: none; position: fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index: 100;">
    <div class="card" style="margin: 50px auto; max-width: 400px;">
        <h3>Add New Part</h3>
        <form id="addPartForm">
            <div class="form-group">
                <label>Part Name</label>
                <input type="text" name="name" class="form-control" required placeholder="e.g Worm Screw">
            </div>
            <div class="form-group">
                <label>Lifetime (HM)</label>
                <input type="number" step="0.1" name="lifetime_hm" class="form-control" required placeholder="e.g 1000">
            </div>
            <div class="flex justify-end mt-4 gap-2">
                <button type="button" class="btn btn-secondary" onclick="closeModal('addPartModal')">Cancel</button>
                <button type="submit" class="btn btn-primary">Save Part</button>
            </div>
        </form>
    </div>
</div>

<!-- Replace Part Modal -->
<div id="replacePartModal" style="display: none; position: fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index: 100;">
    <div class="card" style="margin: 50px auto; max-width: 400px;">
        <h3>Replace Part</h3>
        <p class="text-secondary mb-4">Mencatat penggantian part. Part lama akan dinonaktifkan dan diganti part baru dengan HM 0.</p>
        <form id="replacePartForm">
            <input type="hidden" id="replacePartId" name="part_id">
            <div class="form-group">
                <label>New Part Name (Opsional jika sama)</label>
                <input type="text" id="replacePartName" name="new_name" class="form-control">
            </div>
            <div class="form-group">
                <label>Lifetime (HM)</label>
                <input type="number" step="0.1" id="replacePartLifetime" name="lifetime_hm" class="form-control" required>
            </div>
            <div class="flex justify-end mt-4 gap-2">
                <button type="button" class="btn btn-secondary" onclick="closeModal('replacePartModal')">Cancel</button>
                <button type="submit" class="btn btn-primary">Replace</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Part Modal -->
<% if(user && user.role === 'ADMIN') { %>
<div id="editPartModal" style="display: none; position: fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index: 100;">
    <div class="card" style="margin: 50px auto; max-width: 400px;">
        <h3>Edit Part</h3>
        <form id="editPartForm">
            <input type="hidden" id="editPartId" name="part_id">
            <div class="form-group">
                <label>Part Name</label>
                <input type="text" id="editPartName" name="name" class="form-control" required>
            </div>
            <div class="form-group">
                <label>Lifetime (HM)</label>
                <input type="number" step="0.1" id="editPartLifetime" name="lifetime_hm" class="form-control" required>
            </div>
            <div class="form-group">
                <label>Current HM</label>
                <input type="number" step="0.1" id="editPartCurrent" name="current_hm" class="form-control" required>
            </div>
            <div class="flex justify-end mt-4 gap-2">
                <button type="button" class="btn btn-secondary" onclick="closeModal('editPartModal')">Cancel</button>
                <button type="submit" class="btn btn-primary">Save Changes</button>
            </div>
        </form>
    </div>
</div>
<% } %>

<!-- Record HM Modal -->
<div id="recordHmModal" style="display: none; position: fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index: 100;">
    <div class="card" style="margin: 50px auto; max-width: 400px;">
        <h3>Record Daily HM</h3>
        <p class="text-secondary mb-4">Catat jam operasi mesin untuk hari tertentu. HM ini akan ditambahkan ke semua part yang sedang aktif.</p>
        <form id="recordHmForm">
            <div class="form-group">
                <label>Date</label>
                <input type="date" name="record_date" class="form-control" required id="hmDateInput">
            </div>
            <div class="form-group">
                <label>Operation Hours (HM)</label>
                <input type="number" step="0.1" name="hm_value" class="form-control" required placeholder="e.g 10.5">
            </div>
            <div class="flex justify-end mt-4 gap-2">
                <button type="button" class="btn btn-secondary" onclick="closeModal('recordHmModal')">Cancel</button>
                <button type="submit" class="btn btn-primary">Save HM</button>
            </div>
        </form>
    </div>
</div>

<!-- Add Periodic PM Modal -->
<div id="addPeriodicPMModal" style="display: none; position: fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index: 100;">
    <div class="card" style="margin: 50px auto; max-width: 500px;">
        <h3>Add Periodic PM Plan</h3>
        <form id="addPeriodicPMForm">
            <div class="form-group">
                <label>Plan Name / Description</label>
                <input type="text" name="name" class="form-control" required placeholder="e.g Ganti Oli Rutin">
            </div>
            <div class="flex gap-4">
                <div class="form-group flex-1">
                    <label>Interval Value</label>
                    <input type="number" name="interval_value" class="form-control" required min="1" placeholder="e.g 3">
                </div>
                <div class="form-group flex-1">
                    <label>Interval Type</label>
                    <select name="interval_type" class="form-control" required>
                        <option value="Day">Day(s)</option>
                        <option value="Week">Week(s)</option>
                        <option value="Month">Month(s)</option>
                        <option value="Year">Year(s)</option>
                    </select>
                </div>
            </div>
            <div class="form-group">
                <label>First / Next Due Date</label>
                <input type="date" name="next_due_date" class="form-control" required>
            </div>
            <div class="flex justify-end mt-4 gap-2">
                <button type="button" class="btn btn-secondary" onclick="closeModal('addPeriodicPMModal')">Cancel</button>
                <button type="submit" class="btn btn-primary">Save Plan</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Periodic PM Modal -->
<div id="editPeriodicPMModal" style="display: none; position: fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index: 100;">
    <div class="card" style="margin: 50px auto; max-width: 500px;">
        <h3>Edit Periodic PM Plan</h3>
        <form id="editPeriodicPMForm">
            <input type="hidden" id="editPmId" name="pm_id">
            <div class="form-group">
                <label>Plan Name / Description</label>
                <input type="text" id="editPmName" name="name" class="form-control" required>
            </div>
            <div class="flex gap-4">
                <div class="form-group flex-1">
                    <label>Interval Value</label>
                    <input type="number" id="editPmIntervalValue" name="interval_value" class="form-control" required min="1">
                </div>
                <div class="form-group flex-1">
                    <label>Interval Type</label>
                    <select id="editPmIntervalType" name="interval_type" class="form-control" required>
                        <option value="Day">Day(s)</option>
                        <option value="Week">Week(s)</option>
                        <option value="Month">Month(s)</option>
                        <option value="Year">Year(s)</option>
                    </select>
                </div>
            </div>
            <div class="form-group">
                <label>Next Due Date</label>
                <input type="date" id="editPmNextDue" name="next_due_date" class="form-control" required>
            </div>
            <div class="flex justify-end mt-4 gap-2">
                <button type="button" class="btn btn-secondary" onclick="closeModal('editPeriodicPMModal')">Cancel</button>
                <button type="submit" class="btn btn-primary">Update Plan</button>
            </div>
        </form>
    </div>
</div>

<script>
    // Set default date to today for HM Record
    document.getElementById('hmDateInput').valueAsDate = new Date();

    function openModal(id) { document.getElementById(id).style.display = 'block'; }
    function closeModal(id) { document.getElementById(id).style.display = 'none'; }
    
    function openReplaceModal(partId, name, lifetime) {
        document.getElementById('replacePartId').value = partId;
        document.getElementById('replacePartName').value = name;
        document.getElementById('replacePartLifetime').value = lifetime;
        openModal('replacePartModal');
    }

    function openEditPartModal(partId, name, lifetime, currentHm) {
        document.getElementById('editPartId').value = partId;
        document.getElementById('editPartName').value = name;
        document.getElementById('editPartLifetime').value = lifetime;
        document.getElementById('editPartCurrent').value = currentHm;
        openModal('editPartModal');
    }

    async function deletePart(partId) {
        if (!confirm('Are you sure you want to delete this part? This action cannot be undone.')) return;
        try {
            const res = await fetch(`/api/equipment/<%= equipment.id %>/parts/${partId}`, {
                method: 'DELETE'
            });
            const data = await res.json();
            if(res.ok) window.location.reload();
            else alert(data.error || 'Failed to delete part');
        } catch(err) {
            console.error(err);
            alert('Error deleting part');
        }
    }

    function openEditPMModal(pmId, name, type, value, nextDue) {
        document.getElementById('editPmId').value = pmId;
        document.getElementById('editPmName').value = name;
        document.getElementById('editPmIntervalType').value = type;
        document.getElementById('editPmIntervalValue').value = value;
        document.getElementById('editPmNextDue').value = nextDue;
        openModal('editPeriodicPMModal');
    }

    async function deletePeriodicPM(pmId) {
        if (!confirm('Are you sure you want to delete this PM plan?')) return;
        try {
            const res = await fetch(`/api/equipment/<%= equipment.id %>/periodic-pms/${pmId}`, {
                method: 'DELETE'
            });
            if(res.ok) window.location.reload();
            else alert('Failed to delete PM plan');
        } catch(err) {
            console.error(err);
            alert('Error deleting PM plan');
        }
    }

    const EQUIPMENT_ID = <%= equipment.id %>;

    // Add Part Submit
    document.getElementById('addPartForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        
        try {
            const res = await fetch(`/api/equipment/${EQUIPMENT_ID}/parts`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(Object.fromEntries(formData.entries()))
            });
            if(res.ok) window.location.reload();
            else alert('Failed to add part');
        } catch(err) {
            console.error(err);
            alert('Error adding part');
        }
    });

    // Edit Part Submit
    const editPartForm = document.getElementById('editPartForm');
    if (editPartForm) {
        editPartForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            const partId = formData.get('part_id');
            
            try {
                const res = await fetch(`/api/equipment/${EQUIPMENT_ID}/parts/${partId}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        name: formData.get('name'),
                        lifetime_hm: formData.get('lifetime_hm'),
                        current_hm: formData.get('current_hm')
                    })
                });
                const data = await res.json();
                if(res.ok) window.location.reload();
                else alert(data.error || 'Failed to edit part');
            } catch(err) {
                console.error(err);
                alert('Error editing part');
            }
        });
    }

    // Replace Part Submit
    document.getElementById('replacePartForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        const partId = formData.get('part_id');
        
        try {
            const res = await fetch(`/api/equipment/${EQUIPMENT_ID}/parts/${partId}/replace`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    new_name: formData.get('new_name'),
                    lifetime_hm: formData.get('lifetime_hm')
                })
            });
            if(res.ok) window.location.reload();
            else alert('Failed to replace part');
        } catch(err) {
            console.error(err);
            alert('Error replacing part');
        }
    });

    // Record HM Submit
    document.getElementById('recordHmForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        
        try {
            const res = await fetch(`/api/equipment/${EQUIPMENT_ID}/hm`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(Object.fromEntries(formData.entries()))
            });
            if(res.ok) window.location.reload();
            else alert('Failed to record HM');
        } catch(err) {
            console.error(err);
            alert('Error recording HM');
        }
    });

    // Periodic PM Add Submit
    const addPmForm = document.getElementById('addPeriodicPMForm');
    if (addPmForm) {
        addPmForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            try {
                const res = await fetch(`/api/equipment/${EQUIPMENT_ID}/periodic-pms`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(Object.fromEntries(formData.entries()))
                });
                if(res.ok) window.location.reload();
                else alert('Failed to add PM plan');
            } catch(err) {
                console.error(err);
                alert('Error adding PM plan');
            }
        });
    }

    // Periodic PM Edit Submit
    const editPmForm = document.getElementById('editPeriodicPMForm');
    if (editPmForm) {
        editPmForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            const pmId = formData.get('pm_id');
            try {
                const res = await fetch(`/api/equipment/${EQUIPMENT_ID}/periodic-pms/${pmId}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(Object.fromEntries(formData.entries()))
                });
                if(res.ok) window.location.reload();
                else alert('Failed to edit PM plan');
            } catch(err) {
                console.error(err);
                alert('Error editing PM plan');
            }
        });
    }
</script>
