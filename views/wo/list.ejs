<div class="card">
    <div class="flex justify-between items-center mb-4">
        <h3>Work Orders</h3>
        <% if (user && user.role !== 'SENIOR_MANAGER') { %>
        <a href="/work-orders/create" class="btn btn-primary" style="display: inline-flex; visibility: visible;">
            + Create New WO
        </a>
        <% } %>
    </div>

    <!-- Filters -->
    <form action="/work-orders" method="GET" class="filter-bar mb-4"
        style="display: flex; gap: 1rem; flex-wrap: wrap; align-items: end;">
        <div class="form-group mb-0">
            <label class="form-label" style="font-size: 0.75rem;">Date</label>
            <input type="date" name="date" class="form-control" style="width: 150px;" value="<%= query.date || '' %>">
        </div>


        <div class="form-group mb-0">
            <button type="submit" class="btn btn-secondary">Filter</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table" style="font-size: 0.85rem; white-space: nowrap;">
            <thead>
                <tr>
                    <th>WO No</th>
                    <th>Station</th>
                    <th>Description</th>
                    <th>Priority</th>
                    <% if (user.role !== 'PROC') { %>
                    <th>Plan Type</th>
                    <% } %>
                    <th>Status</th>
                    <% if (user.role === 'ADMIN') { %>
                    <th>Actions</th>
                    <% } %>
                </tr>
            </thead>
            <tbody>
                <% if (wos.length> 0) { %>
                    <% wos.forEach(wo=> { %>
                        <tr onclick="window.location='/work-orders/<%= wo.id %>?readonly=true'" style="cursor: pointer;"
                            class="hover:bg-gray-50">
                            <td><span style="color: var(--primary-color); font-weight: 500;">
                                    <%= wo.wo_no %>
                                </span></td>
                            <td>
                                <%= wo.station.name %>
                            </td>
                            <td style="white-space: normal; min-width: 150px; max-width: 250px; overflow: hidden; text-overflow: ellipsis;">
                                <%= wo.description.length > 40 ? wo.description.substring(0, 40) + '...' : wo.description %>
                            </td>
                            <td><span class="status-<%= wo.priority %>">
                                    <%= wo.priority %>
                                </span></td>
                            <% if (user.role !== 'PROC') { %>
                            <td onclick="event.stopPropagation();">
                                <% if (wo.monthly_plan_status === 'MONTHLY' || wo.monthly_plan_status === 'MONTHLY_DONE') { %>
                                    <span class="badge" style="background: #6366f1; color: white;">Monthly</span>
                                <% } else if (wo.monthly_plan_status === 'NO') { %>
                                    <span class="badge" style="background: #94a3b8; color: white;">No</span>
                                <% } else { %>
                                    <div style="display: flex; gap: 4px;">
                                        <button class="btn btn-sm" style="background: #6366f1; color: white; border: none; padding: 2px 6px; font-size: 0.7rem; border-radius: 4px;" onclick="setPlanType(event, '<%= wo.id %>', 'MONTHLY')">Monthly</button>
                                        <button class="btn btn-sm" style="background: #94a3b8; color: white; border: none; padding: 2px 6px; font-size: 0.7rem; border-radius: 4px;" onclick="setPlanType(event, '<%= wo.id %>', 'NO')">No</button>
                                    </div>
                                <% } %>
                            </td>
                            <% } %>
                            <td><span class="badge status-<%= wo.status %>">
                                    <%= wo.status %>
                                </span></td>
                            <% if (user.role === 'ADMIN') { %>
                                <td>
                                    <% if (wo.status !== 'COMPLETED' && wo.status !== 'CLOSED') { %>
                                        <button class="btn btn-sm" style="background-color: #dc3545; color: white; border: none; padding: 2px 6px; border-radius: 4px; cursor: pointer; font-size: 0.75rem;" onclick="deleteWo(event, '<%= wo.id %>', '<%= wo.wo_no %>')">
                                            <i class="fas fa-trash"></i> Hapus
                                        </button>
                                    <% } else { %>
                                        <span class="text-secondary" style="font-size: 0.8em;">-</span>
                                    <% } %>
                                </td>
                            <% } %>
                        </tr>
                        <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6" class="text-center py-4">No work orders found matching your
                                        criteria.</td>
                                </tr>
                                <% } %>
            </tbody>
        </table>
    </div>
</div>

<script>
    async function deleteWo(e, id, woNo) {
        e.stopPropagation(); // prevent row click from opening details
        if (!confirm(`Yakin ingin MENGHAPUS Work Order ${woNo} secara permanen?\nWork Order yang belum selesai ini akan lenyap dari sistem.`)) return;
        
        try {
            const btn = e.target.closest('button');
            btn.disabled = true;
            btn.innerHTML = 'Hapus...';

            const res = await fetch('/api/work-orders/' + id, { method: 'DELETE' });
            if (res.ok) {
                alert('Work Order berhasil dihapus!');
                window.location.reload();
            } else {
                const data = await res.json();
                alert('Gagal menghapus: ' + (data.error || 'Unknown error'));
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-trash"></i> Hapus';
            }
        } catch (err) {
            console.error(err);
            alert('Terjadi kesalahan koneksi/server.');
        }
    }

    async function setPlanType(e, id, status) {
        e.stopPropagation();
        if(!confirm(`Kunci pilihan menjadi ${status}? Pilihan tidak bisa diubah lagi.`)) return;
        
        try {
            const res = await fetch(`/api/work-orders/${id}/monthly-plan-status`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status })
            });
            
            if (res.ok) {
                window.location.reload();
            } else {
                const data = await res.json();
                alert('Gagal mengunci status: ' + (data.error || 'Unknown error'));
            }
        } catch (error) {
            alert('Terjadi kesalahan koneksi.');
        }
    }
</script>