<div class="card">
    <div class="flex justify-between items-center mb-4">
        <h2>
            <%= wo.wo_no %> <span class="badge status-<%= wo.status %>">
                    <%= wo.status %>
                </span>
        </h2>
        <div class="text-secondary">Created: <%= new Date(wo.created_at).toLocaleString() %>
        </div>
    </div>

    <div class="grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
        <div>
            <label class="form-label">Mill / Station</label>
            <div>
                <%= wo.mill ? wo.mill.name : '?' %> / <%= wo.station ? wo.station.name : '?' %>
            </div>
        </div>
        <div>
            <label class="form-label">Equipment</label>
            <div>
                <%= wo.equipment ? wo.equipment.name : 'General' %>
            </div>
            <% if (wo.equipment) { %> <small class="text-secondary">
                    <%= wo.equipment.code %>
                </small>
                <% } %>
        </div>
        <div>
            <label class="form-label">Category / Type</label>
            <div>
                <%= wo.category %> / <%= wo.type %>
            </div>
        </div>
        <div>
            <label class="form-label">Priority</label>
            <div class="status-<%= wo.priority %>">
                <%= wo.priority %>
            </div>
        </div>
        <div>
            <label class="form-label">Reporter</label>
            <div>
                <%= wo.reporter ? wo.reporter.name : 'Unknown' %>
            </div>
        </div>
        <div>
            <label class="form-label">Assignee</label>
            <div>
                <%= wo.assignee ? wo.assignee.name : 'Unassigned' %>
            </div>
        </div>
    </div>

    <div class="mb-4">
        <label class="form-label">Description</label>
        <div style="background: #f9fafb; padding: 1rem; border-radius: 4px; white-space: pre-wrap;">
            <%= wo.description %>
        </div>
    </div>

    <% if (wo.parts && wo.parts.length > 0) { %>
    <div class="mb-4">
        <label class="form-label">Associated Parts for Replacement</label>
        <div style="background: white; border: 1px solid #e5e7eb; border-radius: 4px; padding: 0.5rem;">
            <ul style="margin: 0; padding-left: 1.5rem;">
                <% wo.parts.forEach(p => { %>
                    <li><strong><%= p.name %></strong> <span class="text-secondary">(HM: <%= p.current_hm %> / <%= p.lifetime_hm %>)</span></li>
                <% }); %>
            </ul>
        </div>
    <% } %>

    <div class="mb-4">
        <div class="flex justify-between items-center mb-2">
            <label class="form-label" style="margin: 0;">Assigned Mechanics / PICs</label>
            <% if (wo.status !== 'COMPLETED' && wo.status !== 'CLOSED' && user.role !== 'PROC') { %>
                <button class="btn btn-sm btn-outline-primary" onclick="openPicModal()">+ Assign PICs</button>
            <% } %>
        </div>
        <div style="background: white; border: 1px solid #e5e7eb; border-radius: 4px; padding: 0.5rem; min-height: 40px;">
            <% if (wo.pics && wo.pics.length > 0) { %>
                <div style="display: flex; flex-wrap: wrap; gap: 8px;">
                    <% wo.pics.forEach(pic => { %>
                        <span class="badge" style="background: #e0e7ff; color: #3730a3; padding: 6px 10px; font-size: 0.85em;">
                            <i class="fas fa-user-wrench" style="margin-right: 4px;"></i> <%= pic.name %>
                        </span>
                    <% }); %>
                </div>
            <% } else { %>
                <span class="text-secondary" style="font-size: 0.9em;">No mechanics assigned yet.</span>
            <% } %>
        </div>
    </div>

    <% if (wo.attachments && wo.attachments.length> 0) { %>
        <div class="mb-4">
            <label class="form-label">Attachments</label>
            <% wo.attachments.forEach(function(att) { %>
                <div class="mb-2 p-2 border rounded">
                    <% if (att.mime_type && att.mime_type.startsWith('image/')) { %>
                        <img src="/uploads/<%= att.file_path %>" alt="<%= att.file_name %>"
                            class="img-fluid rounded mb-2" style="max-height: 400px; display: block;">
                        <% } %>
                            <div class="flex items-center gap-2">
                                <span class="badge badge-secondary">
                                    <%= att.kind %>
                                </span>
                                <a href="/uploads/<%= att.file_path %>" target="_blank"
                                    class="text-blue-600 hover:underline">
                                    <%= att.file_name %>
                                </a>
                            </div>
                </div>
                <% }); %>
        </div>
        <% } %>

            <!-- Activity Log / Comments -->
            <% if (wo.comments && wo.comments.length> 0) { %>
                <div class="mb-4">
                    <label class="form-label">Activity & Comments</label>
                    <div
                        style="border: 1px solid #eee; padding: 1rem; border-radius: 4px; max-height: 200px; overflow-y: auto;">
                        <% wo.comments.forEach(function(c) { %>
                            <div
                                style="margin-bottom: 0.5rem; border-bottom: 1px solid #f9fafb; padding-bottom: 0.5rem;">
                                <strong>
                                    <%= c.user ? c.user.name : 'Unknown' %>
                                </strong>
                                <small class="text-secondary">
                                    <%= new Date(c.created_at).toLocaleString() %>
                                </small>
                                <p style="margin: 0.2rem 0 0 0;">
                                    <%= c.comment %>
                                </p>
                            </div>
                            <% }); %>
                    </div>
                </div>
                <% } %>

                    <!-- Actions -->
                    <% if (user.role !== 'PROC') { %>
                    <div style="border-top: 1px solid #eee; padding-top: 1rem;">
                        <h4>Actions</h4>

                        <!-- Assign (Admin/Spv/Manager/MTC) -->
                        <% if (wo.status==='OPEN' && (user.role==='ADMIN' || user.role==='SPV' || user.role==='MANAGER'
                            || user.role==='MTC' )) { %>
                            <div class="card" style="background: #f9fafb; border: 1px solid #eee;">
                                <h5>Assign Work Order</h5>
                                <div class="flex gap-2">
                                    <select id="assigneeSelect" class="form-control" style="max-width: 200px;">
                                        <option value="">Select Maintainer</option>
                                        <% if (typeof mtcUsers !=='undefined' ) { %>
                                            <% mtcUsers.forEach(function(u) { %>
                                                <option value="<%= u.id %>">
                                                    <%= u.name %>
                                                </option>
                                                <% }); %>
                                                    <% } %>
                                    </select>
                                    <button class="btn btn-primary" onclick="assignUser()">Assign</button>
                                </div>
                            </div>
                            <% } %>

                                <!-- Start Work (Assignee - MTC/Admin Only) -->
                                <% if (wo.status==='ASSIGNED' && (user.role==='MTC' || user.role==='ADMIN' )) { %>
                                    <button class="btn btn-primary" onclick="updateStatus('IN_PROGRESS')">Start
                                        Work</button>
                                    <% } %>

                                        <!-- Complete Work (Assignee) -->
                                        <% if (wo.status==='IN_PROGRESS' ) { %>
                                            <div class="card" style="background: #f9fafb; border: 1px solid #eee;">
                                                <h5>Complete Work</h5>
                                                <div class="form-group">
                                                    <label class="form-label">Action Taken / Resolution</label>
                                                    <textarea id="actionTaken" class="form-control" rows="3"
                                                        placeholder="Describe what was done..."></textarea>
                                                </div>
                                                <div class="form-group">
                                                    <label class="form-label">Upload Repair Photo (Optional)</label>
                                                    <input type="file" id="completionImage" class="form-control">
                                                </div>
                                                <div class="form-group mt-3">
                                                    <label class="form-label" style="font-weight: 600;">Check Parts Replaced:</label>
                                                    <% if (wo.parts && wo.parts.length > 0) { %>
                                                        <div style="background: white; border: 1px solid #e5e7eb; border-radius: 4px; padding: 0.5rem; max-height: 150px; overflow-y: auto;">
                                                            <% wo.parts.forEach(p => { %>
                                                                <label style="display: block; margin-bottom: 0.25rem;">
                                                                    <input type="checkbox" class="replaced-part-cb" value="<%= p.id %>" checked>
                                                                    <%= p.name %>
                                                                </label>
                                                            <% }); %>
                                                        </div>
                                                        <small class="text-secondary">Uncheck any parts that were NOT replaced. They will be returned to the "Need Attention" list on Dashboard.</small>
                                                    <% } else { %>
                                                        <p class="text-secondary" style="margin:0;">No linked parts.</p>
                                                    <% } %>
                                                </div>
                                                <button class="btn btn-success mt-3"
                                                    style="color:white; background-color: var(--success-color);"
                                                    onclick="completeWo()">Complete Work</button>
                                            </div>
                                            <% } %>

                                                <!-- Verification (Spv/Manager) -->
                                                <% if (wo.status==='COMPLETED' ) { %>
                                                    <button onclick="updateStatus('VERIFIED')"
                                                        class="btn btn-primary">Verify</button>
                                                    <button
                                                        onclick="updateStatus('IN_PROGRESS', { comment: 'Rejected, please rework' })"
                                                        class="btn btn-danger">Reject</button>
                                                    <% } %>

                                                        <% if (wo.status==='VERIFIED' ) { %>
                                                            <button onclick="updateStatus('CLOSED')"
                                                                class="btn btn-primary">Close WO</button>
                                                            <% } %>

                    </div>
                    <% } %>
</div>

<!-- Assign PIC Modal -->
<div id="assignPicModal" style="display: none; position: fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index: 100;">
    <div class="card" style="margin: 50px auto; max-width: 500px;">
        <h3>Assign Mechanics (Max 4)</h3>
        <p class="text-secondary mb-3">Please select up to 4 mechanics to work on this order.</p>
        <form id="assignPicForm">
            <div style="max-height: 300px; overflow-y: auto; border: 1px solid #eee; padding: 10px; border-radius: 4px;">
                <% if(typeof workshopEmployees !== 'undefined' && workshopEmployees.length > 0) { %>
                    <% workshopEmployees.forEach(emp => { 
                        const isChecked = wo.pics && wo.pics.some(p => p.id === emp.id) ? 'checked' : '';
                    %>
                        <label style="display: block; margin-bottom: 8px; cursor: pointer;">
                            <input type="checkbox" name="pic_ids" value="<%= emp.id %>" <%= isChecked %> class="pic-checkbox" onchange="checkMaxPics()">
                            <%= emp.name %> <small class="text-secondary">(<%= emp.position || 'Mechanic' %>)</small>
                        </label>
                    <% }); %>
                <% } else { %>
                    <div class="text-secondary text-center">No active workshop employees found for this mill. Data must be inputted by Admin first.</div>
                <% } %>
            </div>
            <div class="flex justify-between mt-4">
                <button type="button" onclick="closePicModal()" class="btn btn-secondary">Cancel</button>
                <button type="submit" class="btn btn-primary" id="savePicBtn">Save PICs</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openPicModal() {
        document.getElementById('assignPicModal').style.display = 'block';
        checkMaxPics();
    }
    
    function closePicModal() {
        document.getElementById('assignPicModal').style.display = 'none';
    }

    function checkMaxPics() {
        const checkboxes = document.querySelectorAll('.pic-checkbox:checked');
        const allCheckboxes = document.querySelectorAll('.pic-checkbox');
        
        if (checkboxes.length >= 4) {
            allCheckboxes.forEach(cb => {
                if (!cb.checked) cb.disabled = true;
            });
        } else {
            allCheckboxes.forEach(cb => cb.disabled = false);
        }
    }

    document.getElementById('assignPicForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        const picIds = formData.getAll('pic_ids');

        if (picIds.length > 4) {
            alert('Maksimal hanya 4 mekanik yang dapat dipilih.');
            return;
        }

        try {
            const res = await fetch('/api/work-orders/<%= wo.id %>/pics', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ pic_ids: picIds })
            });

            if (res.ok) window.location.reload();
            else {
                const err = await res.json();
                alert(err.error || 'Terjadi kesalahan saat menyimpan PIC');
            }
        } catch (error) {
            console.error(error);
            alert('Error connecting to server.');
        }
    });

    const woId = <%= wo.id %>;

    async function updateStatus(status, body = {}) {
        if (!confirm('Update status to ' + status + '?')) return;
        try {
            const res = await fetch('/api/work-orders/' + woId + '/status', {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status: status, ...body })
            });
            if (res.ok) window.location.reload();
            else alert('Error updating status');
        } catch (e) { console.error(e); }
    }

    async function assignUser() {
        const sel = document.getElementById('assigneeSelect');
        const uid = sel.value;
        if (!uid) return alert('Select user');
        await updateStatus('ASSIGNED', { assignee_id: uid });
    }

    async function completeWo() {
        const action = document.getElementById('actionTaken').value;
        if (!action) return alert('Please describe action taken');

        const fileInput = document.getElementById('completionImage');
        if (fileInput.files.length > 0) {
            const fd = new FormData();
            fd.append('file', fileInput.files[0]);
            fd.append('kind', 'completion');
            await fetch('/api/work-orders/' + woId + '/attachments', { method: 'POST', body: fd });
        }

        const checkboxes = document.querySelectorAll('.replaced-part-cb');
        let replacedPartIds = [];
        let replacedNames = [];
        if (checkboxes.length > 0) {
            checkboxes.forEach(cb => {
                if (cb.checked) {
                    replacedPartIds.push(cb.value);
                    replacedNames.push(cb.nextSibling.textContent.trim());
                }
            });
        }

        let commentText = 'ACTION TAKEN: ' + action;
        if (checkboxes.length > 0) {
            commentText = `PARTS REPLACED: ${replacedNames.length > 0 ? replacedNames.join(', ') : 'None'}\n\n` + commentText;
        }

        await updateStatus('COMPLETED', { 
            comment: commentText,
            replaced_part_ids: checkboxes.length > 0 ? replacedPartIds : undefined
        });
    }
</script>