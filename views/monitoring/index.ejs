<style>
@media print {
    body { background: white; margin: 0; padding: 0; font-size: 8pt; }
    .sidebar, .navbar, .topbar, .btn, .d-flex.gap-2, header, footer { display: none !important; }
    .page-content, .main-content { margin: 0 !important; padding: 0 !important; width: 100% !important; }
    .card { border: none !important; box-shadow: none !important; margin: 0 !important; padding: 0 !important; }
    .table-responsive { max-height: none !important; overflow: visible !important; }
    table { width: 100% !important; min-width: 100% !important; font-size: 7pt !important; }
    * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
    @page { size: landscape; margin: 5mm; }
    /* Force sticky columns to act normally on print to avoid rendering bugs */
    th, td { position: static !important; }
}
</style>
<div class="card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Jadwal Target vs Actual <%= typeof type !== 'undefined' ? type : 'WO' %></h2>
        <div class="d-flex gap-2">
            <% 
                const currentStart = new Date(startDateStr);
                const prevStart = new Date(currentStart);
                prevStart.setDate(currentStart.getDate() - 7);
                const nextStart = new Date(currentStart);
                nextStart.setDate(currentStart.getDate() + 7);
                
                const todayStart = new Date();
                todayStart.setDate(todayStart.getDate() - 3);
            %>
            <a href="?startDate=<%= prevStart.toISOString().split('T')[0] %>" class="btn btn-outline-secondary btn-sm">
                <i class="fas fa-arrow-left"></i> Prev 7 Hari
            </a>
            <a href="?startDate=<%= todayStart.toISOString().split('T')[0] %>" class="btn btn-outline-secondary btn-sm">
                Hari Ini
            </a>
            <a href="?startDate=<%= nextStart.toISOString().split('T')[0] %>" class="btn btn-outline-secondary btn-sm">
                Next 7 Hari <i class="fas fa-arrow-right"></i>
            </a>
            <button onclick="window.print()" class="btn btn-primary btn-sm ms-2">
                <i class="fas fa-print"></i> Print
            </button>
        </div>
    </div>

    <div class="table-responsive" style="max-height: 70vh; overflow-y: auto;">
        <table class="table table-bordered table-sm text-center align-middle" style="min-width: 1200px; font-size: 0.8rem;">
            <thead style="position: sticky; top: 0; z-index: 10;">
                <tr style="background-color: #1e293b; color: #ffffff; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px;">
                    <th rowspan="2" style="width: 40px; min-width: 40px; max-width: 40px; padding: 12px 5px; position: sticky; left: 0; z-index: 11; background-color: #1e293b; color: #ffffff; box-shadow: 1px 0 0 #0f172a; border: none; border-bottom: 3px solid #0f172a; vertical-align: middle;">NO</th>
                    <th rowspan="2" style="width: 350px; min-width: 350px; text-align: left; padding: 12px 10px; position: sticky; left: 40px; z-index: 11; background-color: #1e293b; color: #ffffff; box-shadow: 1px 0 0 #0f172a; border: none; border-bottom: 3px solid #0f172a; vertical-align: middle;">JUDUL PROGRAM</th>
                    <th rowspan="2" style="width: 100px; padding: 12px 8px; background-color: #1e293b; color: #ffffff; border: none; border-bottom: 3px solid #0f172a; border-right: 1px solid rgba(255,255,255,0.05); vertical-align: middle;">STASIUN</th>
                    <th rowspan="2" style="width: 120px; padding: 12px 8px; background-color: #1e293b; color: #ffffff; border: none; border-bottom: 3px solid #0f172a; border-right: 1px solid rgba(255,255,255,0.05); vertical-align: middle;">PIC</th>
                    <th rowspan="2" style="width: 80px; padding: 12px 8px; background-color: #1e293b; color: #ffffff; border: none; border-bottom: 3px solid #0f172a; border-right: 1px solid rgba(255,255,255,0.05); vertical-align: middle;">STATUS</th>
                    <% dates.forEach(d => { 
                        // Determine if it's weekend
                        const isWeekend = d.date.getDay() === 0 || d.date.getDay() === 6;
                        const bgColor = isWeekend ? '#0f172a' : '#1e293b';
                    %>
                        <th style="width: 40px; padding: 8px 2px; background-color: <%= bgColor %>; color: #ffffff; border: none; border-bottom: 3px solid #0f172a; border-right: 1px solid rgba(255,255,255,0.05); vertical-align: middle;">
                            <div style="font-size: 1.1rem; font-weight: bold; text-shadow: 1px 1px 2px rgba(0,0,0,0.5);"><%= d.dayStr %></div>
                            <div style="font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.5px; opacity: 0.9;"><%= d.monthStr %></div>
                        </th>
                    <% }); %>
                </tr>
            </thead>
            <tbody>
                <% if (wos && wos.length > 0) { %>
                    <% wos.forEach((wo, index) => { %>
                        <% 
                            // Determine Target range (created_at to target_finish, or just created_at)
                            const targetStart = new Date(wo.created_at);
                            targetStart.setHours(0,0,0,0);
                            const targetFinish = wo.target_finish ? new Date(wo.target_finish) : new Date(targetStart);
                            targetFinish.setHours(23,59,59,999);

                            // Determine Actual range (started_at to completed_at/closed_at, or today if ongoing)
                            let actualStart = null;
                            let actualFinish = null;
                            if (wo.started_at) {
                                actualStart = new Date(wo.started_at);
                                actualStart.setHours(0,0,0,0);
                                if (wo.completed_at) {
                                    actualFinish = new Date(wo.completed_at);
                                } else if (wo.closed_at) {
                                    actualFinish = new Date(wo.closed_at);
                                } else if (wo.status !== 'CLOSED' && wo.status !== 'COMPLETED') {
                                    // Ongoing
                                    actualFinish = new Date(); 
                                } else {
                                    actualFinish = new Date(actualStart);
                                }
                                actualFinish.setHours(23,59,59,999);
                            }
                        %>
                        <!-- Target Row -->
                        <tr>
                            <td rowspan="2" style="width: 40px; min-width: 40px; max-width: 40px; padding-left: 5px; padding-right: 5px; position: sticky; left: 0; z-index: 1; background-color: #fff; box-shadow: 1px 0 0 #dee2e6;"><%= index + 1 %></td>
                            <td rowspan="2" class="text-start" style="position: sticky; left: 40px; z-index: 1; background-color: #fff; box-shadow: 1px 0 0 #dee2e6;">
                                <strong><%= wo.wo_no %></strong><br>
                                <span class="text-muted"><%= wo.description %></span>
                            </td>
                            <td rowspan="2"><%= wo.station ? wo.station.name : '-' %></td>
                            <td rowspan="2">
                                <% if (wo.assignee) { %>
                                    <%= wo.assignee.name %>
                                <% } else if (wo.pics && wo.pics.length > 0) { %>
                                    <%= wo.pics.map(p => p.name).join(', ') %>
                                <% } else { %>
                                    -
                                <% } %>
                            </td>
                            <td>
                                <span class="badge" style="background-color: #fef3c7; color: #d97706; border: 1px solid #fde68a; font-size: 0.65rem; padding: 3px 5px;">TARGET</span>
                            </td>
                            <% dates.forEach(d => { 
                                const currentDay = new Date(d.date);
                                currentDay.setHours(12,0,0,0);
                                let isTarget = (currentDay >= targetStart && currentDay <= targetFinish);
                            %>
                                <td style="padding: 2px;">
                                    <% if (isTarget) { %>
                                        <div style="background-color: #fcd34d; width: 100%; height: 24px; border-radius: 2px;"></div>
                                    <% } %>
                                </td>
                            <% }); %>
                        </tr>
                        <!-- Actual Row -->
                        <tr>
                            <td style="border-bottom-width: 2px; padding: 2px;">
                                <span class="badge" style="background-color: #d1fae5; color: #059669; border: 1px solid #a7f3d0; font-size: 0.65rem; padding: 3px 5px;">ACTUAL</span>
                            </td>
                            <% dates.forEach(d => { 
                                const currentDay = new Date(d.date);
                                currentDay.setHours(12,0,0,0);
                                let isActual = actualStart && actualFinish && (currentDay >= actualStart && currentDay <= actualFinish);
                            %>
                                <td style="padding: 2px; border-bottom-width: 2px;">
                                    <% if (isActual) { %>
                                        <div style="background-color: #6ee7b7; width: 100%; height: 24px; border-radius: 2px;"></div>
                                    <% } %>
                                </td>
                            <% }); %>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="<%= 5 + dates.length %>" class="text-center py-4 text-muted">
                            Tidak ada data Work Order pada rentang waktu ini.
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</div>
