<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Weekly Maintenance Plan - <%= today %></title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #333;
            line-height: 1.4;
            max-width: 100%;
            margin: 0;
            padding: 10px;
        }

        .header {
            text-align: center;
            margin-bottom: 10px;
            border-bottom: 2px solid #333;
            padding-bottom: 10px;
            margin-top: 0px;
        }

        .header h1 {
            margin: 0;
            font-size: 24px;
        }

        .header p {
            margin: 5px 0 0;
            color: #666;
        }

        .section {
            margin-bottom: 10px;
        }

        .section-title {
            font-size: 18px;
            font-weight: bold;
            margin-bottom: 15px;
            border-left: 5px solid #007bff;
            padding-left: 10px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 24px;
        }

        th,
        td {
            border: 1px solid #ddd;
            padding: 8px;
            text-align: left;
        }

        th {
            background-color: #e9ecef;
            border-bottom: 2px solid #333;
            font-weight: bold;
            color: #495057;
        }

        tr:nth-child(even) {
            background-color: #f8f9fa;
        }

        @media print {
            tr:nth-child(even) {
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
                background-color: #f2f2f2 !important;
            }

            th {
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
                background-color: #e9ecef !important;
            }
            body {
                padding: 0;
            }
            .no-print {
                display: none;
            }
            a {
                text-decoration: none;
                color: #333;
            }
        }

        .print-controls {
            margin-bottom: 20px;
            text-align: right;
        }

        .btn {
            display: inline-block;
            padding: 8px 16px;
            background-color: #007bff;
            color: white;
            text-decoration: none;
            border-radius: 4px;
            font-size: 14px;
            cursor: pointer;
            border: none;
        }

        .btn-secondary {
            background-color: #6c757d;
        }
    </style>
</head>

<body>
    <div class="print-controls no-print">
        <button onclick="window.print()" class="btn">🖨️ Print Page</button>
        <button onclick="window.close()" class="btn btn-secondary">Close</button>
    </div>

    <div class="header" style="position: relative;">
        <h2><%= typeof isProcessing !== 'undefined' && isProcessing ? 'Processing Weekly Plan' : (typeof isCivil !== 'undefined' && isCivil ? 'Civil Weekly Plan' : (typeof isOffice !== 'undefined' && isOffice ? 'Office Weekly Plan' : 'Maintenance Weekly Plan')) %></h2>
        <div class="meta">
            Mill: <strong>BUNGA TANJUNG MILL</strong> |
            Week: <strong><%= query.week || 'ALL' %></strong> |
            Day: <strong><%= query.day || 'ALL' %></strong> |
            Printed: <strong><%= today %></strong>
        </div>
        <p>Printed by: <%= user.name %> (<%= user.role %>)</p>

        <% if (query.week || query.day) { %>
            <div style="position: absolute; top: 0; right: 0; text-align: left; padding: 8px; background: #eee; border: 1px solid #ddd; font-size: 12px;">
                <strong>Filter Applied:</strong><br>
                <% if (query.week) { %><span>Week: <%= query.week %></span><br><% } %>
                <% if (query.day) { %><span>Day: <%= query.day %></span><% } %>
            </div>
        <% } %>
    </div>

    <div class="section">
        <div class="section-title">Maintenance Plan</div>
        <table>
            <thead>
                <tr>
                    <th style="width: 20%;">Station</th>
                    <th style="width: 65%;">Description</th>
                    <% if (typeof isProcessing === 'undefined' || !isProcessing) { %>
                    <th style="width: 15%;">PIC</th>
                    <% } %>
                </tr>
            </thead>
            <tbody>
                <% if (Object.keys(groupedPlans).length > 0) { %>
                    <% for (const category in groupedPlans) { %>
                        <tr style="background-color: #d1ecf1; border-top: 2px solid #333;">
                            <td colspan="<%= (typeof isProcessing === 'undefined' || !isProcessing) ? 3 : 2 %>" style="font-weight: bold; font-size: 24px; text-transform: uppercase;">
                                KATEGORI: <%= category %>
                            </td>
                        </tr>
                        <% groupedPlans[category].forEach(plan => { %>
                            <tr>
                                <td><%= plan.wo.station ? plan.wo.station.name : '-' %></td>
                                <td><%= plan.wo.description %></td>
                                <% if (typeof isProcessing === 'undefined' || !isProcessing) { %>
                                <td>
                                    <% if (plan.wo.pics && plan.wo.pics.length > 0) { %>
                                        <%= plan.wo.pics.map(p => p.name).join(', ') %>
                                    <% } else { %>
                                        -
                                    <% } %>
                                </td>
                                <% } %>
                            </tr>
                        <% }); %>
                    <% } %>
                <% } else { %>
                    <tr>
                        <td colspan="<%= (typeof isProcessing === 'undefined' || !isProcessing) ? 3 : 2 %>" style="text-align: center; padding: 20px;">No planned work found matching the criteria.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>

    <div style="margin-top: 50px; display: flex; justify-content: space-between;">
        <div style="text-align: center; width: 200px;">
            <p>Prepared By,</p>
            <br><br><br>
            <p>( <%= user.name %> )</p>
        </div>
        <div style="text-align: center; width: 200px;">
            <p>Approved By,</p>
            <br><br><br>
            <p>( __________________ )</p>
        </div>
    </div>

    <script>
        // Optional auto-print trigger if they opened this page meant to be printed
        // window.onload = function() { window.print(); }
    </script>
</body>

</html>
