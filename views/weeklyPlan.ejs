<div class="card">
    <div class="flex justify-between items-center mb-4">
        <h3><%= typeof title !== 'undefined' ? title : (typeof isProcessing !== 'undefined' && isProcessing ? 'Processing Weekly Plan' : (typeof isCivil !== 'undefined' && isCivil ? 'Civil Weekly Plan' : (typeof isOffice !== 'undefined' && isOffice ? 'Office Weekly Plan' : 'Weekly Plan'))) %></h3>
        <% if (user && user.role !== 'PROC' && user.role !== 'SENIOR_MANAGER' && (typeof isProcessing === 'undefined' || !isProcessing) && (typeof isCivil === 'undefined' || !isCivil) && (typeof isOffice === 'undefined' || !isOffice) && (typeof isOffice === 'undefined' || !isOffice)) { %>
            <button type="button" class="btn btn-primary" onclick="openNonWoModal()">+ Add Non-WO Job</button>
        <% } %>
    </div>

    <% if (user && user.role !== 'PROC' && user.role !== 'SENIOR_MANAGER' && (typeof isProcessing === 'undefined' || !isProcessing) && (typeof isOffice === 'undefined' || !isOffice)) { %>
    <div class="card mb-4" style="border-left: 4px solid #17a2b8;">
        <div class="flex justify-between items-center mb-2">
            <h4 style="margin: 0;">Find Unfinished Work</h4>
            <div class="flex gap-2">
                <button type="button" class="btn btn-info text-white" onclick="openFilterModal()"><i class="fas fa-search"></i> Search / Filter WO</button>
                <% if (query.candidateStartDate || query.candidateStations) { %>
                    <a href="/weekly-plan?week=<%= query.week || '' %>" class="btn btn-secondary">Clear Filter</a>
                <% } %>
            </div>
        </div>
        
        <% if (query.candidateStartDate && query.candidateEndDate) { %>
            <div class="text-sm text-secondary">
                <strong>Active Filter:</strong> Date <%= query.candidateStartDate %> to <%= query.candidateEndDate %>, 
                Stations: <%= query.candidateStations ? (Array.isArray(query.candidateStations) ? query.candidateStations.length + ' stations' : '1 station') : 'All' %>
            </div>
        <% } %>

        <% if (typeof candidateWos !=='undefined' && candidateWos.length> 0) { %>
            <hr class="my-3">
            <h5 class="mb-3">Select WOs to Plan</h5>
            <form action="/api/weekly-plan/bulk" method="POST">
                <div class="mb-3">
                    <button type="button" class="btn btn-primary" onclick="openSortirModal()">Sortir</button>
                </div>

                <div class="table-responsive" style="max-height: 300px; overflow-y: auto;">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th width="40"><input type="checkbox" onclick="toggleAll(this)"></th>
                                <th>WO No</th>
                                <th>Date</th>
                                <th>Priority</th>
                                <th>Current Plan</th>
                                <th>Status</th>
                                <th>Description</th>
                                <th>PIC</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% candidateWos.forEach(wo=> { %>
                                <tr>
                                    <td>
                                        <input type="checkbox" name="wo_ids[]" value="<%= wo.id %>">
                                    </td>
                                    <td>
                                        <%= wo.wo_no %>
                                        <% if (wo.monthly_plan_status === 'MONTHLY_DONE') { %>
                                            <span class="badge" style="background: #10b981; color: white; font-size: 0.6rem; margin-left: 5px;">Material Ready</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <%= new Date(wo.created_at).toLocaleDateString() %>
                                    </td>
                                    <td><span class="badge badge-<%= wo.priority === 'P1' ? 'danger' : 'secondary' %>">
                                            <%= wo.priority %>
                                        </span></td>
                                    <td>
                                        <% if (wo.weekly_plan) { %>
                                            <%= wo.weekly_plan.planned_week %> (<%= wo.weekly_plan.planned_day || '-' %>)
                                        <% } else { %>
                                            <span class="text-muted italic text-sm">Unplanned</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <span class="badge badge-<%= wo.status === 'OPEN' ? 'warning' : (wo.status === 'IN PROGRESS' ? 'info' : 'secondary') %>">
                                            <%= wo.status %>
                                        </span>
                                    </td>
                                    <td>
                                        <%= wo.description.substring(0, 50) %>...
                                    </td>
                                    <td>
                                        <% if (wo.pics && wo.pics.length > 0) { %>
                                            <%= wo.pics.map(p => p.name).join(', ') %>
                                        <% } else { %>
                                            <span class="text-muted italic text-sm">Belum ada</span>
                                        <% } %>
                                        <% if (user && user.role !== 'PROC' && user.role !== 'SENIOR_MANAGER') { %>
                                            <div class="mt-2 no-print">
                                                <button type="button" class="btn btn-sm" style="background-color: #e2e8f0; color: #1e293b; border: 1px solid #cbd5e1; font-size: 0.75rem; font-weight: 600;" onclick="openGlobalPicModal(<%= wo.id %>, <%= JSON.stringify((wo.pics || []).map(p => p.id)) %>)">+ Assign PICs</button>
                                            </div>
                                        <% } %>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                </div>
            </form>
            <script>
                function toggleAll(source) {
                    checkboxes = document.getElementsByName('wo_ids[]');
                    for (var i = 0, n = checkboxes.length; i < n; i++) {
                        checkboxes[i].checked = source.checked;
                    }
                }
            </script>
            <% } else { %>
                <p class="text-muted italic">No unfinished work orders found.</p>
                <% } %>
    </div>
    <% } %>

    <% if ((typeof isProcessing !== 'undefined' && isProcessing) || (typeof isCivil !== 'undefined' && isCivil) || (typeof isOffice !== 'undefined' && isOffice)) { %>
    <div class="print-header hidden-print-block">
        <h2 class="text-center mb-4"><%= typeof title !== 'undefined' ? title : (typeof isProcessing !== 'undefined' && isProcessing ? 'Processing Weekly Plan' : (typeof isCivil !== 'undefined' && isCivil ? 'Civil Weekly Plan' : (typeof isOffice !== 'undefined' && isOffice ? 'Office Weekly Plan' : 'Maintenance Weekly Plan'))) %></h2>
        <div class="flex justify-between mb-4">
            <div><strong>Week:</strong>
                <%= query.week || 'All' %>
            </div>
            <div><strong>Day:</strong>
                <%= query.day || 'All' %>
            </div>
        </div>
    </div>
    <% } %>

    <div class="flex justify-between items-center mb-4">
        <h4><%= (typeof isProcessing === 'undefined' || !isProcessing) && (typeof isCivil === 'undefined' || !isCivil) && (typeof isOffice === 'undefined' || !isOffice) ? 'Record Program kerja' : (typeof title !== 'undefined' ? title : 'Weekly Plan') %></h4>
        <form action="<%= typeof isProcessing !== 'undefined' && isProcessing ? '/weekly-plan/processing' : (typeof isCivil !== 'undefined' && isCivil ? '/weekly-plan/civil' : (typeof isOffice !== 'undefined' && isOffice ? '/weekly-plan/office' : '/weekly-plan')) %>" method="GET" class="flex gap-2 items-center" id="filterForm">
            <% if ((typeof isProcessing !== 'undefined' && isProcessing) || (typeof isCivil !== 'undefined' && isCivil) || (typeof isOffice !== 'undefined' && isOffice)) { %>
            <div class="form-group mb-0">
                <input type="text" name="week" class="form-control" placeholder="Week (e.g. 2026-W06)"
                    value="<%= query.week || '' %>">
            </div>
            <div class="form-group mb-0">
                <select name="day" class="form-control">
                    <option value="">All Days</option>
                    <% ['Monday', 'Tuesday' , 'Wednesday' , 'Thursday' , 'Friday' , 'Saturday' , 'Sunday' ].forEach(d=>
                        { %>
                        <option value="<%= d %>" <%=query.day===d ? 'selected' : '' %>><%= d %>
                        </option>
                        <% }) %>
                </select>
            </div>
            <button type="submit" class="btn btn-secondary">Filter</button>
            <% } %>
            <button type="button" class="btn btn-primary" onclick="printPlan()">
                <i class="fas fa-print"></i> Print Plan
            </button>
        </form>
    </div>

    <script>
        function printPlan() {
            const week = document.querySelector('input[name="week"]').value;
            const day = document.querySelector('select[name="day"]').value;
            let url = '<%= typeof isProcessing !== "undefined" && isProcessing ? "/weekly-plan/processing/print" : (typeof isCivil !== "undefined" && isCivil ? "/weekly-plan/civil/print" : (typeof isOffice !== "undefined" && isOffice ? "/weekly-plan/office/print" : "/weekly-plan/print")) %>?';
            if (week) url += `week=${week}&`;
            if (day) url += `day=${day}`;
            window.open(url, '_blank');
        }
    </script>

    <div class="table-responsive">
        <table class="table">
            <% if ((typeof isProcessing === 'undefined' || !isProcessing) && (typeof isCivil === 'undefined' || !isCivil) && (typeof isOffice === 'undefined' || !isOffice)) { %>
                <% 
                    let groupedPlans = {};
                    plans.forEach(plan => {
                        let pd = plan.planned_day || 'Unassigned Date';
                        if (!groupedPlans[pd]) groupedPlans[pd] = [];
                        groupedPlans[pd].push(plan);
                    });
                    const dates = Object.keys(groupedPlans).sort((a, b) => {
                        if (a === 'Unassigned Date') return 1;
                        if (b === 'Unassigned Date') return -1;
                        
                        const isDateA = a.includes('-');
                        const isDateB = b.includes('-');
                        
                        if (isDateA && isDateB) {
                            return new Date(b) - new Date(a);
                        } else if (isDateA) {
                            return -1;
                        } else if (isDateB) {
                            return 1;
                        } else {
                            return a.localeCompare(b);
                        }
                    });
                %>
                <% if (dates.length > 0) { %>
                    <thead>
                        <tr style="background-color: #f8fafc;">
                            <th width="50">NO</th>
                            <th width="100">BULAN</th>
                            <th>KETERANGAN</th>
                        </tr>
                    </thead>
                    <tbody>
                    <% dates.forEach((date, index) => { %>
                        <% 
                            let monthStr = '-';
                            let formattedDate = date;
                            if (date !== 'Unassigned Date' && date.includes('-')) { 
                                const dt = new Date(date);
                                const optionsDate = { day: 'numeric', month: 'long', year: 'numeric' };
                                formattedDate = dt.toLocaleDateString('id-ID', optionsDate);
                                // Format month like Jun-26
                                const monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
                                const m = monthNames[dt.getMonth()];
                                const y = dt.getFullYear().toString().slice(-2);
                                monthStr = `${m}-${y}`;
                            }
                        %>
                        <tr>
                            <td><%= index + 1 %></td>
                            <td><%= monthStr %></td>
                            <td>
                                <a href="/weekly-plan/print?day=<%= date %>" target="_blank" style="text-decoration: none; color: #1e293b; font-weight: 500;" class="hover:text-blue-600">
                                    <% if (date !== 'Unassigned Date' && date.includes('-')) { %>
                                        Program kerja Maintenance tanggal <%= formattedDate %>
                                    <% } else { %>
                                        Program kerja Maintenance - <%= date %>
                                    <% } %>
                                    <i class="fas fa-print" style="margin-left: 8px; color: #3b82f6; font-size: 0.9em;"></i>
                                </a>
                            </td>
                        </tr>
                    <% }); %>
                    </tbody>
                <% } else { %>
                    <tbody>
                        <tr>
                            <td colspan="3" class="text-center py-4">No planned work found.</td>
                        </tr>
                    </tbody>
                <% } %>
            <% } else { %>
            <thead>
                <tr>
                    <th>Week</th>
                    <th>Day</th>
                    <th>WO No</th>
                    <th>Station</th>
                    <th>Description</th>
                    <th>Planner</th>
                </tr>
            </thead>
            <tbody>
                <% if (plans.length> 0) { %>
                    <% plans.forEach(plan=> { %>
                        <tr>
                            <td>
                                <%= plan.planned_week %>
                            </td>
                            <td>
                                <%= plan.planned_day || '-' %>
                            </td>
                            <td><a href="/work-orders/<%= plan.wo.id %>">
                                    <%= plan.wo.wo_no %>
                                </a></td>
                            <td>
                                <%= plan.wo.station.name %>
                            </td>
                            <td>
                                <%= plan.wo.description %>
                            </td>
                            <td>
                                <%= plan.planner.name %>
                            </td>
                        </tr>
                        <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="6" class="text-center py-4">No planned work found.</td>
                                </tr>
                                <% } %>
            </tbody>
            <% } %>
        </table>
    </div>

<!-- Assign PIC Modal -->
<div id="assignGlobalPicModal" style="display: none; position: fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index: 10000;">
    <div class="card" style="margin: 50px auto; max-width: 500px; position: relative;">
        <h3>Assign Mechanics (Max 4)</h3>
        <p class="text-secondary mb-3">Please select up to 4 mechanics to work on this order.</p>
        <form id="assignGlobalPicForm">
            <input type="hidden" id="activeWoId" name="wo_id" value="">
            <div style="max-height: 300px; overflow-y: auto; border: 1px solid #eee; padding: 10px; border-radius: 4px;">
                <% if(typeof workshopEmployees !== 'undefined' && workshopEmployees.length > 0) { %>
                    <% workshopEmployees.forEach(emp => { %>
                        <label style="display: block; margin-bottom: 8px; cursor: pointer;">
                            <input type="checkbox" name="pic_ids" value="<%= emp.id %>" class="global-pic-checkbox" onchange="checkGlobalMaxPics()">
                            <%= emp.name %> <small class="text-secondary">(<%= emp.position || 'Mechanic' %>)</small>
                        </label>
                    <% }); %>
                <% } else { %>
                    <div class="text-secondary text-center">No active workshop employees found.</div>
                <% } %>
            </div>
            <div class="flex justify-between mt-4">
                <button type="button" onclick="closeGlobalPicModal()" class="btn btn-secondary">Cancel</button>
                <button type="submit" class="btn btn-primary" id="saveGlobalPicBtn">Save PICs</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openGlobalPicModal(woId, currentPicIds) {
        document.getElementById('activeWoId').value = woId;
        
        // Reset and check current
        const checkboxes = document.querySelectorAll('.global-pic-checkbox');
        checkboxes.forEach(cb => {
            cb.checked = currentPicIds.includes(parseInt(cb.value));
            cb.disabled = false;
        });

        document.getElementById('assignGlobalPicModal').style.display = 'block';
        checkGlobalMaxPics();
    }
    
    function closeGlobalPicModal() {
        document.getElementById('assignGlobalPicModal').style.display = 'none';
        document.getElementById('activeWoId').value = "";
    }

    function checkGlobalMaxPics() {
        const checkboxes = document.querySelectorAll('.global-pic-checkbox:checked');
        const allCheckboxes = document.querySelectorAll('.global-pic-checkbox');
        
        if (checkboxes.length >= 4) {
            allCheckboxes.forEach(cb => {
                if (!cb.checked) cb.disabled = true;
            });
        } else {
            allCheckboxes.forEach(cb => cb.disabled = false);
        }
    }

    document.getElementById('assignGlobalPicForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        const picIds = formData.getAll('pic_ids');
        const woId = document.getElementById('activeWoId').value;

        if (picIds.length > 4) {
            alert('Maksimal hanya 4 mekanik yang dapat dipilih.');
            return;
        }

        try {
            const res = await fetch(`/api/work-orders/${woId}/pics`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ pic_ids: picIds })
            });

            if (res.ok) window.location.reload();
            else {
                const err = await res.json();
                alert(err.error || 'Terjadi kesalahan saat menyimpan PIC');
            }
        } catch (error) {
            console.error(error);
            alert('Error connecting to server.');
        }
    });
</script>

<!-- Add Non-WO Job Modal -->
<div id="nonWoModal" style="display: none; position: fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index: 10000;">
    <div class="card" style="margin: 30px auto; max-width: 600px; position: relative; max-height: 90vh; overflow-y: auto;">
        <h3>Add Non-WO / Fabrication Job</h3>
        <form id="nonWoForm">
            <div class="form-group">
                <label class="form-label">Category *</label>
                <select name="category" class="form-control" required>
                    <option value="">-- Select Category --</option>
                    <option value="Mechanical">Mechanical</option>
                    <option value="Electrical">Electrical</option>
                    <option value="Fabrication">Fabrication</option>
                    <option value="Civil">Civil</option>
                    <option value="Instrument">Instrument</option>
                    <option value="Others">Others</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Station *</label>
                <select name="station_id" class="form-control" required>
                    <option value="">-- Select Station --</option>
                    <% if(typeof stations !== 'undefined') { %>
                        <% stations.forEach(s => { %>
                            <option value="<%= s.id %>"><%= s.name %></option>
                        <% }); %>
                    <% } %>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Description *</label>
                <textarea name="description" class="form-control" rows="3" required placeholder="Jelaskan detail pekerjaan..."></textarea>
            </div>
            <div class="flex gap-4">
                <div class="form-group flex-grow">
                    <label class="form-label">Target Week *</label>
                    <input type="text" name="planned_week" class="form-control" required value="<%= typeof currentWeek !== 'undefined' ? currentWeek : (query.week || '') %>">
                </div>
                <div class="form-group flex-grow">
                    <label class="form-label">Target Day *</label>
                    <select name="planned_day" class="form-control" required>
                        <option value="">-- Select Day --</option>
                        <option value="Monday">Monday</option>
                        <option value="Tuesday">Tuesday</option>
                        <option value="Wednesday">Wednesday</option>
                        <option value="Thursday">Thursday</option>
                        <option value="Friday">Friday</option>
                        <option value="Saturday">Saturday</option>
                        <option value="Sunday">Sunday</option>
                    </select>
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Assign Mechanics (Max 4)</label>
                <div style="max-height: 150px; overflow-y: auto; border: 1px solid #eee; padding: 10px; border-radius: 4px;">
                    <% if(typeof workshopEmployees !== 'undefined' && workshopEmployees.length > 0) { %>
                        <% workshopEmployees.forEach(emp => { %>
                            <label style="display: block; margin-bottom: 8px; cursor: pointer;">
                                <input type="checkbox" name="pic_ids" value="<%= emp.id %>" class="nonwo-pic-checkbox" onchange="checkNonWoMaxPics()">
                                <%= emp.name %> <small class="text-secondary">(<%= emp.position || 'Mechanic' %>)</small>
                            </label>
                        <% }); %>
                    <% } else { %>
                        <div class="text-secondary text-center">No active workshop employees found.</div>
                    <% } %>
                </div>
            </div>
            
            <div class="flex justify-between mt-4">
                <button type="button" onclick="closeNonWoModal()" class="btn btn-secondary">Cancel</button>
                <button type="submit" class="btn btn-primary" id="saveNonWoBtn">Add to Plan</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openNonWoModal() {
        document.getElementById('nonWoModal').style.display = 'block';
    }
    
    function closeNonWoModal() {
        document.getElementById('nonWoModal').style.display = 'none';
        document.getElementById('nonWoForm').reset();
    }

    function checkNonWoMaxPics() {
        const checkboxes = document.querySelectorAll('.nonwo-pic-checkbox:checked');
        const allCheckboxes = document.querySelectorAll('.nonwo-pic-checkbox');
        
        if (checkboxes.length >= 4) {
            allCheckboxes.forEach(cb => {
                if (!cb.checked) cb.disabled = true;
            });
        } else {
            allCheckboxes.forEach(cb => cb.disabled = false);
        }
    }

    document.getElementById('nonWoForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        
        // Convert to JSON
        const data = {};
        formData.forEach((value, key) => {
            if (key === 'pic_ids') {
                if (!data[key]) data[key] = [];
                data[key].push(value);
            } else {
                data[key] = value;
            }
        });

        document.getElementById('saveNonWoBtn').disabled = true;
        document.getElementById('saveNonWoBtn').innerText = "Saving...";

        try {
            const res = await fetch('/api/weekly-plan/non-wo', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            if (res.ok) {
                window.location.reload();
            } else {
                const err = await res.json();
                alert(err.error || 'Terjadi kesalahan saat menambahkan Non-WO Job');
                document.getElementById('saveNonWoBtn').disabled = false;
                document.getElementById('saveNonWoBtn').innerText = "Add to Plan";
            }
        } catch (error) {
            console.error(error);
            alert('Error connecting to server.');
            document.getElementById('saveNonWoBtn').disabled = false;
            document.getElementById('saveNonWoBtn').innerText = "Add to Plan";
        }
    });
</script>
<!-- Sortir Modal -->
<div id="sortirModal" style="display: none; position: fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index: 10000;">
    <div class="card" style="margin: 50px auto; max-width: 400px; position: relative;">
        <h3>Program kerja harian</h3>
        <p class="text-secondary mb-3">Pilih tanggal untuk program kerja ini.</p>
        <div class="form-group">
            <label class="form-label">Tanggal Program *</label>
            <input type="date" id="sortirDate" class="form-control" required>
        </div>
        <div class="flex justify-between mt-4">
            <button type="button" onclick="closeSortirModal()" class="btn btn-secondary">Batal</button>
            <button type="button" class="btn btn-primary" onclick="submitSortir()">OK</button>
        </div>
    </div>
</div>

<script>
    function openSortirModal() {
        // Validate at least one WO is checked
        const checkboxes = document.querySelectorAll('input[name="wo_ids[]"]:checked');
        if (checkboxes.length === 0) {
            alert("Pilih minimal satu Work Order untuk disortir.");
            return;
        }
        document.getElementById('sortirDate').value = new Date().toISOString().split('T')[0];
        document.getElementById('sortirModal').style.display = 'block';
    }
    
    function closeSortirModal() {
        document.getElementById('sortirModal').style.display = 'none';
    }

    function submitSortir() {
        const dateVal = document.getElementById('sortirDate').value;
        if (!dateVal) {
            alert("Tanggal Program harus diisi.");
            return;
        }

        // We need to submit the form but include the selected date as planned_week and planned_day.
        // Or we can dynamically append hidden inputs to the main form and submit it.
        const form = document.querySelector('form[action="/api/weekly-plan/bulk"]');
        
        // Remove existing planned_week and planned_day if they exist
        const oldWeek = form.querySelector('input[name="planned_week"]');
        if (oldWeek) oldWeek.remove();
        const oldDay = form.querySelector('input[name="planned_day"]');
        if (oldDay) oldDay.remove();

        const getISOWeekString = (dStr) => {
            const date = new Date(dStr);
            const d = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));
            const dayNum = d.getUTCDay() || 7;
            d.setUTCDate(d.getUTCDate() + 4 - dayNum);
            const year = d.getUTCFullYear();
            const weekNo = Math.ceil((((d - new Date(Date.UTC(year, 0, 1))) / 86400000) + 1) / 7);
            return `${year}-W${String(weekNo).padStart(2, '0')}`;
        };

        const plannedWeekInput = document.createElement('input');
        plannedWeekInput.type = 'hidden';
        plannedWeekInput.name = 'planned_week';
        plannedWeekInput.value = getISOWeekString(dateVal); // Store ISO week

        const plannedDayInput = document.createElement('input');
        plannedDayInput.type = 'hidden';
        plannedDayInput.name = 'planned_day';
        plannedDayInput.value = dateVal; // Store the exact Date

        form.appendChild(plannedWeekInput);
        form.appendChild(plannedDayInput);

        form.submit();
    }
</script>
<!-- Filter Modal -->
<div id="filterModal" style="display: none; position: fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index: 10000;">
    <div class="card" style="margin: 50px auto; max-width: 500px; position: relative;">
        <h3>Search & Filter WO</h3>
        <form action="<%= typeof isProcessing !== 'undefined' && isProcessing ? '/weekly-plan/processing' : (typeof isCivil !== 'undefined' && isCivil ? '/weekly-plan/civil' : (typeof isOffice !== 'undefined' && isOffice ? '/weekly-plan/office' : '/weekly-plan')) %>" method="GET">
            <input type="hidden" name="week" value="<%= query.week || '' %>">
            
            <div class="form-group">
                <label>Date Range (WO Created Date)</label>
                <div class="flex gap-2 items-center">
                    <input type="date" name="candidateStartDate" class="form-control" value="<%= query.candidateStartDate || '' %>" required>
                    <span>to</span>
                    <input type="date" name="candidateEndDate" class="form-control" value="<%= query.candidateEndDate || '' %>" required>
                </div>
            </div>

            <div class="form-group">
                <label>Stations</label>
                <div style="max-height: 250px; overflow-y: auto; border: 1px solid #ccc; padding: 10px; border-radius: 4px;">
                    <label style="display: block; font-weight: bold; margin-bottom: 8px; border-bottom: 1px solid #eee; padding-bottom: 8px;">
                        <input type="checkbox" id="selectAllStations" onclick="toggleAllStations(this)"> Pilih Semua Stasiun
                    </label>
                    <% if(typeof stations !== 'undefined') { %>
                        <% stations.forEach(s => { 
                            let isChecked = false;
                            if (query.candidateStations) {
                                if (Array.isArray(query.candidateStations)) {
                                    isChecked = query.candidateStations.includes(s.id.toString());
                                } else {
                                    isChecked = query.candidateStations === s.id.toString();
                                }
                            }
                        %>
                            <label style="display: block; margin-bottom: 5px; cursor: pointer;">
                                <input type="checkbox" name="candidateStations" value="<%= s.id %>" class="station-checkbox" <%= isChecked ? 'checked' : '' %>>
                                <%= s.name %>
                            </label>
                        <% }); %>
                    <% } %>
                </div>
            </div>

            <div class="flex justify-end gap-2 mt-4">
                <button type="button" class="btn btn-secondary" onclick="closeFilterModal()">Batal / No</button>
                <button type="submit" class="btn btn-primary">OK</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openFilterModal() { document.getElementById('filterModal').style.display = 'block'; }
    function closeFilterModal() { document.getElementById('filterModal').style.display = 'none'; }
    function toggleAllStations(source) {
        let checkboxes = document.querySelectorAll('.station-checkbox');
        for(let i=0, n=checkboxes.length; i<n; i++) {
            checkboxes[i].checked = source.checked;
        }
    }
</script>
</div>