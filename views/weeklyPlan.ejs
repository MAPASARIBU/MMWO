<div class="card">
    <div class="flex justify-between items-center mb-4">
        <h3>Weekly Plan</h3>
        <button type="button" class="btn btn-primary" onclick="openNonWoModal()">+ Add Non-WO Job</button>
    </div>

    <div class="card mb-4" style="border-left: 4px solid #17a2b8;">
        <h4>Find Unfinished Work</h4>
        <form action="/weekly-plan" method="GET" class="flex gap-4 items-end mb-4">
            <!-- Persist current week filter if any -->
            <input type="hidden" name="week" value="<%= query.week || '' %>">

            <div class="form-group mb-0">
                <label class="text-sm text-gray-600">From</label>
                <input type="date" name="candidateStart" class="form-control" value="<%= query.candidateStart || '' %>"
                    required>
            </div>
            <div class="form-group mb-0">
                <label class="text-sm text-gray-600">To</label>
                <input type="date" name="candidateEnd" class="form-control" value="<%= query.candidateEnd || '' %>"
                    required>
            </div>
            <button type="submit" class="btn btn-info text-white">Find Candidates</button>
            <% if (query.candidateStart) { %>
                <a href="/weekly-plan?week=<%= query.week || '' %>" class="btn btn-secondary">Clear</a>
                <% } %>
        </form>

        <% if (typeof candidateWos !=='undefined' && candidateWos.length> 0) { %>
            <hr class="my-3">
            <h5 class="mb-3">Select WOs to Plan</h5>
            <form action="/api/weekly-plan/bulk" method="POST">
                <div class="flex gap-4 mb-3 p-3 bg-gray-50 rounded">
                    <div class="form-group mb-0 flex-grow">
                        <label class="text-sm font-bold">Target Week * (This Week)</label>
                        <input type="text" name="planned_week" class="form-control"
                            style="background-color: #e9ecef; cursor: not-allowed;" readonly
                            value="<%= typeof currentWeek !== 'undefined' ? currentWeek : (query.week || '') %>">
                    </div>
                    <div class="form-group mb-0 flex-grow">
                        <label class="text-sm font-bold">Target Day</label>
                        <select name="planned_day" class="form-control">
                            <option value="">-- Select Day --</option>
                            <option value="Monday">Monday</option>
                            <option value="Tuesday">Tuesday</option>
                            <option value="Wednesday">Wednesday</option>
                            <option value="Thursday">Thursday</option>
                            <option value="Friday">Friday</option>
                            <option value="Saturday">Saturday</option>
                            <option value="Sunday">Sunday</option>
                        </select>
                    </div>
                    <div class="flex items-end">
                        <button type="submit" class="btn btn-success">Add to Plan</button>
                    </div>
                </div>

                <div class="table-responsive" style="max-height: 300px; overflow-y: auto;">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th width="40"><input type="checkbox" onclick="toggleAll(this)"></th>
                                <th>WO No</th>
                                <th>Date</th>
                                <th>Priority</th>
                                <th>Current Plan</th>
                                <th>Status</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% candidateWos.forEach(wo=> { %>
                                <tr>
                                    <td>
                                        <input type="checkbox" name="wo_ids[]" value="<%= wo.id %>">
                                    </td>
                                    <td>
                                        <%= wo.wo_no %>
                                    </td>
                                    <td>
                                        <%= new Date(wo.created_at).toLocaleDateString() %>
                                    </td>
                                    <td><span class="badge badge-<%= wo.priority === 'P1' ? 'danger' : 'secondary' %>">
                                            <%= wo.priority %>
                                        </span></td>
                                    <td>
                                        <% if (wo.weekly_plan) { %>
                                            <%= wo.weekly_plan.planned_week %> (<%= wo.weekly_plan.planned_day || '-' %>)
                                        <% } else { %>
                                            <span class="text-muted italic text-sm">Unplanned</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <span class="badge badge-<%= wo.status === 'OPEN' ? 'warning' : (wo.status === 'IN PROGRESS' ? 'info' : 'secondary') %>">
                                            <%= wo.status %>
                                        </span>
                                    </td>
                                    <td>
                                        <%= wo.description.substring(0, 50) %>...
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                </div>
            </form>
            <script>
                function toggleAll(source) {
                    checkboxes = document.getElementsByName('wo_ids[]');
                    for (var i = 0, n = checkboxes.length; i < n; i++) {
                        checkboxes[i].checked = source.checked;
                    }
                }
            </script>
            <% } else if (query.candidateStart) { %>
                <p class="text-muted italic">No unfinished work orders found in this range.</p>
                <% } %>
    </div>

    <div class="print-header hidden-print-block">
        <h2 class="text-center mb-4">Weekly Maintenance Plan</h2>
        <div class="flex justify-between mb-4">
            <div><strong>Week:</strong>
                <%= query.week || 'All' %>
            </div>
            <div><strong>Day:</strong>
                <%= query.day || 'All' %>
            </div>
        </div>
    </div>

    <form action="/weekly-plan" method="GET" class="filter-bar mb-4 no-print">
        <div class="flex gap-2">
            <div class="form-group mb-0">
                <input type="text" name="week" class="form-control" placeholder="Week (e.g. 2026-W06)"
                    value="<%= query.week || '' %>">
            </div>
            <div class="form-group mb-0">
                <select name="day" class="form-control">
                    <option value="">All Days</option>
                    <% ['Monday', 'Tuesday' , 'Wednesday' , 'Thursday' , 'Friday' , 'Saturday' , 'Sunday' ].forEach(d=>
                        { %>
                        <option value="<%= d %>" <%=query.day===d ? 'selected' : '' %>><%= d %>
                        </option>
                        <% }) %>
                </select>
            </div>
            <button type="submit" class="btn btn-secondary">Filter</button>
            <a href="/weekly-plan/print?week=<%= query.week || '' %>&day=<%= query.day || '' %>" target="_blank" class="btn btn-primary" style="text-decoration: none;">
                <i class="fas fa-print"></i> Print Plan
            </a>
        </div>
        </div>
    </form>
    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>Week</th>
                    <th>Day</th>
                    <th>WO No</th>
                    <th>Station</th>
                    <th>Description</th>
                    <th>Planner</th>
                    <th>PIC</th>
                </tr>
            </thead>
            <tbody>
                <% if (plans.length> 0) { %>
                    <% plans.forEach(plan=> { %>
                        <tr>
                            <td>
                                <%= plan.planned_week %>
                            </td>
                            <td>
                                <%= plan.planned_day || '-' %>
                            </td>
                            <td><a href="/work-orders/<%= plan.wo.id %>">
                                    <%= plan.wo.wo_no %>
                                </a></td>
                            <td>
                                <%= plan.wo.station.name %>
                            </td>
                            <td>
                                <%= plan.wo.description %>
                            </td>
                            <td>
                                <%= plan.planner.name %>
                            </td>
                            <td>
                                <% if (plan.wo.pics && plan.wo.pics.length > 0) { %>
                                    <%= plan.wo.pics.map(p => p.name).join(', ') %>
                                <% } else { %>
                                    <span class="text-muted italic text-sm">Belum ada</span>
                                <% } %>
                                <% if (user && user.role !== 'PROC') { %>
                                    <div class="mt-2 no-print">
                                        <button type="button" class="btn btn-sm" style="background-color: #e2e8f0; color: #1e293b; border: 1px solid #cbd5e1; font-size: 0.75rem; font-weight: 600;" onclick="openGlobalPicModal(<%= plan.wo.id %>, <%= JSON.stringify((plan.wo.pics || []).map(p => p.id)) %>)">+ Assign PICs</button>
                                    </div>
                                <% } %>
                            </td>
                        </tr>
                        <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="7" class="text-center py-4">No planned work found.</td>
                                </tr>
                                <% } %>
            </tbody>
        </table>
    </div>

<!-- Assign PIC Modal -->
<div id="assignGlobalPicModal" style="display: none; position: fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index: 10000;">
    <div class="card" style="margin: 50px auto; max-width: 500px; position: relative;">
        <h3>Assign Mechanics (Max 4)</h3>
        <p class="text-secondary mb-3">Please select up to 4 mechanics to work on this order.</p>
        <form id="assignGlobalPicForm">
            <input type="hidden" id="activeWoId" name="wo_id" value="">
            <div style="max-height: 300px; overflow-y: auto; border: 1px solid #eee; padding: 10px; border-radius: 4px;">
                <% if(typeof workshopEmployees !== 'undefined' && workshopEmployees.length > 0) { %>
                    <% workshopEmployees.forEach(emp => { %>
                        <label style="display: block; margin-bottom: 8px; cursor: pointer;">
                            <input type="checkbox" name="pic_ids" value="<%= emp.id %>" class="global-pic-checkbox" onchange="checkGlobalMaxPics()">
                            <%= emp.name %> <small class="text-secondary">(<%= emp.position || 'Mechanic' %>)</small>
                        </label>
                    <% }); %>
                <% } else { %>
                    <div class="text-secondary text-center">No active workshop employees found.</div>
                <% } %>
            </div>
            <div class="flex justify-between mt-4">
                <button type="button" onclick="closeGlobalPicModal()" class="btn btn-secondary">Cancel</button>
                <button type="submit" class="btn btn-primary" id="saveGlobalPicBtn">Save PICs</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openGlobalPicModal(woId, currentPicIds) {
        document.getElementById('activeWoId').value = woId;
        
        // Reset and check current
        const checkboxes = document.querySelectorAll('.global-pic-checkbox');
        checkboxes.forEach(cb => {
            cb.checked = currentPicIds.includes(parseInt(cb.value));
            cb.disabled = false;
        });

        document.getElementById('assignGlobalPicModal').style.display = 'block';
        checkGlobalMaxPics();
    }
    
    function closeGlobalPicModal() {
        document.getElementById('assignGlobalPicModal').style.display = 'none';
        document.getElementById('activeWoId').value = "";
    }

    function checkGlobalMaxPics() {
        const checkboxes = document.querySelectorAll('.global-pic-checkbox:checked');
        const allCheckboxes = document.querySelectorAll('.global-pic-checkbox');
        
        if (checkboxes.length >= 4) {
            allCheckboxes.forEach(cb => {
                if (!cb.checked) cb.disabled = true;
            });
        } else {
            allCheckboxes.forEach(cb => cb.disabled = false);
        }
    }

    document.getElementById('assignGlobalPicForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        const picIds = formData.getAll('pic_ids');
        const woId = document.getElementById('activeWoId').value;

        if (picIds.length > 4) {
            alert('Maksimal hanya 4 mekanik yang dapat dipilih.');
            return;
        }

        try {
            const res = await fetch(`/api/work-orders/${woId}/pics`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ pic_ids: picIds })
            });

            if (res.ok) window.location.reload();
            else {
                const err = await res.json();
                alert(err.error || 'Terjadi kesalahan saat menyimpan PIC');
            }
        } catch (error) {
            console.error(error);
            alert('Error connecting to server.');
        }
    });
</script>

<!-- Add Non-WO Job Modal -->
<div id="nonWoModal" style="display: none; position: fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index: 10000;">
    <div class="card" style="margin: 30px auto; max-width: 600px; position: relative; max-height: 90vh; overflow-y: auto;">
        <h3>Add Non-WO / Fabrication Job</h3>
        <form id="nonWoForm">
            <div class="form-group">
                <label class="form-label">Category *</label>
                <select name="category" class="form-control" required>
                    <option value="">-- Select Category --</option>
                    <option value="Mechanical">Mechanical</option>
                    <option value="Electrical">Electrical</option>
                    <option value="Fabrication">Fabrication</option>
                    <option value="Civil">Civil</option>
                    <option value="Instrument">Instrument</option>
                    <option value="Others">Others</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Station *</label>
                <select name="station_id" class="form-control" required>
                    <option value="">-- Select Station --</option>
                    <% if(typeof stations !== 'undefined') { %>
                        <% stations.forEach(s => { %>
                            <option value="<%= s.id %>"><%= s.name %></option>
                        <% }); %>
                    <% } %>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">Description *</label>
                <textarea name="description" class="form-control" rows="3" required placeholder="Jelaskan detail pekerjaan..."></textarea>
            </div>
            <div class="flex gap-4">
                <div class="form-group flex-grow">
                    <label class="form-label">Target Week *</label>
                    <input type="text" name="planned_week" class="form-control" required value="<%= typeof currentWeek !== 'undefined' ? currentWeek : (query.week || '') %>">
                </div>
                <div class="form-group flex-grow">
                    <label class="form-label">Target Day *</label>
                    <select name="planned_day" class="form-control" required>
                        <option value="">-- Select Day --</option>
                        <option value="Monday">Monday</option>
                        <option value="Tuesday">Tuesday</option>
                        <option value="Wednesday">Wednesday</option>
                        <option value="Thursday">Thursday</option>
                        <option value="Friday">Friday</option>
                        <option value="Saturday">Saturday</option>
                        <option value="Sunday">Sunday</option>
                    </select>
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Assign Mechanics (Max 4)</label>
                <div style="max-height: 150px; overflow-y: auto; border: 1px solid #eee; padding: 10px; border-radius: 4px;">
                    <% if(typeof workshopEmployees !== 'undefined' && workshopEmployees.length > 0) { %>
                        <% workshopEmployees.forEach(emp => { %>
                            <label style="display: block; margin-bottom: 8px; cursor: pointer;">
                                <input type="checkbox" name="pic_ids" value="<%= emp.id %>" class="nonwo-pic-checkbox" onchange="checkNonWoMaxPics()">
                                <%= emp.name %> <small class="text-secondary">(<%= emp.position || 'Mechanic' %>)</small>
                            </label>
                        <% }); %>
                    <% } else { %>
                        <div class="text-secondary text-center">No active workshop employees found.</div>
                    <% } %>
                </div>
            </div>
            
            <div class="flex justify-between mt-4">
                <button type="button" onclick="closeNonWoModal()" class="btn btn-secondary">Cancel</button>
                <button type="submit" class="btn btn-primary" id="saveNonWoBtn">Add to Plan</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openNonWoModal() {
        document.getElementById('nonWoModal').style.display = 'block';
    }
    
    function closeNonWoModal() {
        document.getElementById('nonWoModal').style.display = 'none';
        document.getElementById('nonWoForm').reset();
    }

    function checkNonWoMaxPics() {
        const checkboxes = document.querySelectorAll('.nonwo-pic-checkbox:checked');
        const allCheckboxes = document.querySelectorAll('.nonwo-pic-checkbox');
        
        if (checkboxes.length >= 4) {
            allCheckboxes.forEach(cb => {
                if (!cb.checked) cb.disabled = true;
            });
        } else {
            allCheckboxes.forEach(cb => cb.disabled = false);
        }
    }

    document.getElementById('nonWoForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        
        // Convert to JSON
        const data = {};
        formData.forEach((value, key) => {
            if (key === 'pic_ids') {
                if (!data[key]) data[key] = [];
                data[key].push(value);
            } else {
                data[key] = value;
            }
        });

        document.getElementById('saveNonWoBtn').disabled = true;
        document.getElementById('saveNonWoBtn').innerText = "Saving...";

        try {
            const res = await fetch('/api/weekly-plan/non-wo', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            if (res.ok) {
                window.location.reload();
            } else {
                const err = await res.json();
                alert(err.error || 'Terjadi kesalahan saat menambahkan Non-WO Job');
                document.getElementById('saveNonWoBtn').disabled = false;
                document.getElementById('saveNonWoBtn').innerText = "Add to Plan";
            }
        } catch (error) {
            console.error(error);
            alert('Error connecting to server.');
            document.getElementById('saveNonWoBtn').disabled = false;
            document.getElementById('saveNonWoBtn').innerText = "Add to Plan";
        }
    });
</script>
</div>